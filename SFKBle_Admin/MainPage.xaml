                                TextColor="Black"
                                VerticalTextAlignment="Center" />
                        </Grid>

                        <!--  LIST  -->
                        <ListView
                            x:Name="lstRemoteConnection"
                            BackgroundColor="#F5F5F5"
                            HasUnevenRows="True"
                            IsVisible="True"
                            SelectionMode="None"
                            SeparatorVisibility="None">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <ViewCell>
                                        <Grid
                                            Padding="10,12"
                                            ColumnDefinitions="{OnIdiom Phone='2*,2*,2*,2.5*',
                                                                        Tablet='1.5*,1.5*,1.5*,1*'}"
                                            VerticalOptions="Center">

                                            <!--  DATE + TIME (2 LINES)  -->
                                            <StackLayout
                                                Grid.Column="0"
                                                Spacing="2"
                                                VerticalOptions="Start">
                                                <Label
                                                    FontSize="{OnIdiom Phone=14,
                                                                       Tablet=16}"
                                                    Text="{Binding CreatedDate, StringFormat='{0:dd/MM/yy}'}"
                                                    TextColor="Black" />

                                                <Label
                                                    FontSize="{OnIdiom Phone=13,
                                                                       Tablet=15}"
                                                    Text="{Binding CreatedDate, StringFormat='{0:HH:mm:ss}'}"
                                                    TextColor="#555555" />
                                            </StackLayout>

                                            <!--  STATUS  -->
                                            <Label
                                                Grid.Column="1"
                                                FontAttributes="Bold"
                                                FontSize="{OnIdiom Phone=13,
                                                                   Tablet=17}"
                                                HorizontalTextAlignment="Start"
                                                Text="{Binding SessionStatus}"
                                                TextColor="{Binding SessionStatus, Converter={StaticResource StatusToColorConverter}}"
                                                VerticalTextAlignment="Center" />

                                            <!--  Customer Name (ALIGNED WITH HEADER)  -->
                                            <Label
                                                Grid.Column="2"
                                                FontSize="{OnIdiom Phone=14,
                                                                   Tablet=17}"
                                                HorizontalTextAlignment="Start"
                                                LineBreakMode="TailTruncation"
                                                Text="{Binding CustomerName}"
                                                TextColor="Black"
                                                VerticalTextAlignment="Center" />

                                            <!--  PIN OR ACTION BUTTONS  -->
                                            <Grid
                                                Grid.Column="3"
                                                HorizontalOptions="End"
                                                VerticalOptions="Center">
                                                <!--  PIN SECTION  -->
                                                <Frame
                                                    Padding="10,5"
                                                    BackgroundColor="#FFF3CD"
                                                    BorderColor="#FFC107"
                                                    CornerRadius="6"
                                                    HasShadow="False"
                                                    HorizontalOptions="End"
                                                    VerticalOptions="Center">
                                                    <Frame.Triggers>
                                                        <DataTrigger
                                                            Binding="{Binding SessionStatus}"
                                                            TargetType="Frame"
                                                            Value="PENDING">
                                                            <Setter Property="IsVisible" Value="True" />
                                                        </DataTrigger>
                                                    </Frame.Triggers>

                                                    <Frame.Style>
                                                        <Style TargetType="Frame">
                                                            <Setter Property="IsVisible" Value="False" />
                                                        </Style>
                                                    </Frame.Style>

                                                    <StackLayout Orientation="Horizontal" Spacing="5">
                                                        <Label
                                                            CharacterSpacing="3"
                                                            FontAttributes="Bold"
                                                            FontSize="{OnIdiom Phone=17,
                                                                               Tablet=18}"
                                                            Text="{Binding VerificationPIN}"
                                                            TextColor="Black"
                                                            VerticalTextAlignment="Center" />
                                                    </StackLayout>
                                                </Frame>
                                                <!--  ACTION BUTTONS  -->
                                                <StackLayout
                                                    HorizontalOptions="End"
                                                    Orientation="Horizontal"
                                                    Spacing="5">
                                                    <StackLayout.Triggers>
                                                        <DataTrigger
                                                            Binding="{Binding SessionStatus}"
                                                            TargetType="StackLayout"
                                                            Value="PENDING">
                                                            <Setter Property="IsVisible" Value="False" />
                                                        </DataTrigger>
                                                    </StackLayout.Triggers>
                                                    <ImageButton
                                                        x:Name="imgbtnAcceptRequest"
                                                        ClassId="{Binding DeviceID}"
                                                        Clicked="imgbtnAcceptRequest_Clicked"
                                                        HeightRequest="35"
                                                        HorizontalOptions="End"
                                                        IsEnabled="{Binding ClickEnable}"
                                                        Source="{Binding EnableImage}"
                                                        WidthRequest="35" />
                                                    <ImageButton
                                                        x:Name="imgbtnDeclineRequest"
                                                        ClassId="{Binding DeviceID}"
                                                        Clicked="imgbtnDeclineRequest_Clicked"
                                                        HeightRequest="35"
                                                        HorizontalOptions="End"
                                                        IsEnabled="{Binding ClickEnable}"
                                                        Source="{Binding DisableImage}"
                                                        WidthRequest="35" />
                                                </StackLayout>
                                            </Grid>
                                        </Grid>
                                    </ViewCell>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <Label
                            x:Name="lblNotFound"
                            Margin="0,20,0,20"
                            FontAttributes="Bold"
                            FontSize="{OnIdiom Phone=15,
                                               Tablet=17}"
                            HorizontalOptions="CenterAndExpand"
                            HorizontalTextAlignment="Center"
                            IsVisible="False"
                            Text="No Request Found."
                            TextColor="red"
                            VerticalOptions="FillAndExpand"
                            VerticalTextAlignment="Center" />
                    </StackLayout>
                </Frame>
                <StackLayout
                    HorizontalOptions="Center"
                    IsVisible="True"
                    Orientation="Horizontal"
                    Spacing="10"
                    VerticalOptions="End">
                    <Frame
                        x:Name="btnClearAll"
                        Padding="15,10"
                        BackgroundColor="#14B729"
                        CornerRadius="6">
                        <StackLayout Orientation="Horizontal" Spacing="8">
                            <Image
                                HeightRequest="20"
                                Source="delete.png"
                                VerticalOptions="Center"
                                WidthRequest="20" />
                            <Label
                                FontAttributes="Bold"
                                FontSize="{OnIdiom Phone=16,
                                                   Tablet=19}"
                                Text="Clear All"
                                TextColor="White"
                                VerticalOptions="Center" />
                        </StackLayout>
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="btnClearAll_Tapped" />
                        </Frame.GestureRecognizers>
                    </Frame>
                    <Frame
                        x:Name="btnMuteAll"
                        Padding="15,10"
                        BackgroundColor="#f90b0b"
                        CornerRadius="6">
                        <StackLayout Orientation="Horizontal" Spacing="8">
                            <Image
                                HeightRequest="20"
                                Source="mute.png"
                                VerticalOptions="Center"
                                WidthRequest="20" />
                            <Label
                                FontAttributes="Bold"
                                FontSize="{OnIdiom Phone=16,
                                                   Tablet=19}"
                                Text="Mute"
                                TextColor="White"
                                VerticalOptions="Center" />
                        </StackLayout>
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="btnMuteAll_Tapped" />
                        </Frame.GestureRecognizers>
                    </Frame>
                </StackLayout>
            </StackLayout>
        </StackLayout>
        <!--  Remote Connection End  -->
    </Grid>
</ContentPage>