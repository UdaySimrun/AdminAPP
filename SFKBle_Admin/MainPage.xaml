<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SFKBle_Admin.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:core="clr-namespace:Syncfusion.Maui.Core;assembly=Syncfusion.Maui.Core"
    xmlns:input="clr-namespace:InputKit.Shared.Controls;assembly=InputKit.Maui"
    xmlns:local="clr-namespace:SFKBle.Models"
    xmlns:pinview="clr-namespace:PINView.Maui;assembly=PINView.Maui"
    xmlns:progressBar="clr-namespace:Syncfusion.Maui.ProgressBar;assembly=Syncfusion.Maui.ProgressBar"
    xmlns:syncfusion="clr-namespace:Syncfusion.Maui.Core;assembly=Syncfusion.Maui.Core"
    BackgroundColor="White"
    NavigationPage.HasNavigationBar="False">
    <ContentPage.Resources>
        <ResourceDictionary>
            <local:StatusToColorConverter x:Key="StatusToColorConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>
    <Grid>
        <Grid
            x:Name="gridMain"
            Grid.Row="0"
            IsEnabled="False"
            VerticalOptions="FillAndExpand">
            <Grid.RowDefinitions>
                <RowDefinition x:Name="rowDefinationHeader" Height="50" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <StackLayout
                x:Name="stackHeader"
                Grid.Row="0"
                HeightRequest="45"
                HorizontalOptions="FillAndExpand"
                Orientation="Vertical"
                VerticalOptions="Start">
                <StackLayout
                    Padding="5,0,5,0"
                    HorizontalOptions="FillAndExpand"
                    Orientation="Horizontal"
                    VerticalOptions="FillAndExpand">
                    <Image Source="sunfunkitslogowtb.png" WidthRequest="70" />
                    <Label
                        Padding="10,0,0,0"
                        FontAttributes="Bold"
                        FontSize="15"
                        HorizontalOptions="CenterAndExpand"
                        IsVisible="False"
                        Text="www.sunfunkits.com"
                        TextColor="Black" />
                    <Label
                        FontSize="15"
                        HorizontalOptions="FillAndExpand"
                        HorizontalTextAlignment="End"
                        Text="V9.38"
                        TextColor="Black"
                        VerticalOptions="Center" />
                </StackLayout>
                <BoxView
                    BackgroundColor="#f0c000"
                    HeightRequest="1"
                    HorizontalOptions="FillAndExpand"
                    VerticalOptions="Start" />
            </StackLayout>
            <StackLayout
                x:Name="stackMainStackLayout"
                Grid.Row="1"
                HorizontalOptions="FillAndExpand"
                Orientation="Horizontal"
                VerticalOptions="FillAndExpand">
                <StackLayout
                    x:Name="stackAvailableData"
                    BackgroundColor="Transparent"
                    HorizontalOptions="FillAndExpand"
                    VerticalOptions="FillAndExpand">
                    <Image
                        x:Name="imgBatteryScanVertical"
                        Margin="{OnIdiom Phone='0,10,0,0',
                                         Tablet='0,20,0,0'}"
                        BackgroundColor="Transparent"
                        HorizontalOptions="FillAndExpand"
                        IsVisible="False"
                        MaximumHeightRequest="{OnIdiom Phone='70',
                                                       Tablet='120'}"
                        Source="scanbatteryicon.png"
                        VerticalOptions="Fill" />
                    <StackLayout
                        x:Name="stackAvailableDataInner"
                        Margin="40,20,40,20"
                        BackgroundColor="Transparent"
                        HorizontalOptions="FillAndExpand"
                        IsVisible="False"
                        VerticalOptions="FillAndExpand">
                        <Border
                            BackgroundColor="Transparent"
                            HorizontalOptions="FillAndExpand"
                            StrokeThickness="0"
                            VerticalOptions="FillAndExpand">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="5" />
                            </Border.StrokeShape>
                            <StackLayout
                                HorizontalOptions="FillAndExpand"
                                Spacing="10"
                                VerticalOptions="FillAndExpand">
                                <Border
                                    x:Name="brdTabView"
                                    BackgroundColor="#e3e3e3"
                                    HorizontalOptions="FillAndExpand"
                                    StrokeThickness="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="{OnIdiom Phone='10', Tablet='7'}" />
                                    </Border.StrokeShape>
                                    <StackLayout
                                        HorizontalOptions="FillAndExpand"
                                        Orientation="Horizontal"
                                        VerticalOptions="FillAndExpand">
                                        <Border
                                            x:Name="brdDevieListTab"
                                            BackgroundColor="#e3e3e3"
                                            ClassId="DeviceList"
                                            HorizontalOptions="FillAndExpand"
                                            StrokeThickness="0"
                                            VerticalOptions="FillAndExpand">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="{OnIdiom Phone='7', Tablet='7'}" />
                                            </Border.StrokeShape>
                                            <Label
                                                HorizontalOptions="CenterAndExpand"
                                                Style="{StaticResource ScanTabFont}"
                                                Text="Device List"
                                                TextColor="#333333"
                                                VerticalOptions="CenterAndExpand" />
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="ListTabChange_Tapped" />
                                            </Border.GestureRecognizers>
                                        </Border>
                                        <Border
                                            x:Name="brdVirtualBatteryListTab"
                                            BackgroundColor="#e3e3e3"
                                            ClassId="VirtualBatteryList"
                                            HorizontalOptions="FillAndExpand"
                                            IsVisible="True"
                                            StrokeThickness="0"
                                            VerticalOptions="FillAndExpand">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="{OnIdiom Phone='7', Tablet='7'}" />
                                            </Border.StrokeShape>
                                            <Label
                                                HorizontalOptions="CenterAndExpand"
                                                Style="{StaticResource ScanTabFont}"
                                                Text="Virtual Battery List"
                                                TextColor="#333333"
                                                VerticalOptions="CenterAndExpand" />
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="ListTabChange_Tapped" />
                                            </Border.GestureRecognizers>
                                        </Border>
                                    </StackLayout>
                                </Border>
                                <Border StrokeThickness="1" VerticalOptions="FillAndExpand">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="{OnIdiom Phone='10', Tablet='7'}" />
                                    </Border.StrokeShape>
                                    <StackLayout
                                        HorizontalOptions="FillAndExpand"
                                        Orientation="Vertical"
                                        VerticalOptions="FillAndExpand">
                                        <!--  Device List  -->
                                        <StackLayout
                                            x:Name="stackDeviceList"
                                            IsVisible="False"
                                            VerticalOptions="FillAndExpand">
                                            <ListView
                                                x:Name="lstDeviceList"
                                                BackgroundColor="White"
                                                IsVisible="False"
                                                RowHeight="70"
                                                Scrolled="lstDeviceList_Scrolled"
                                                SelectionMode="None"
                                                SeparatorVisibility="None"
                                                VerticalOptions="FillAndExpand"
                                                VerticalScrollBarVisibility="Never">
                                                <ListView.ItemTemplate>
                                                    <DataTemplate>
                                                        <ViewCell>
                                                            <ViewCell.View>
                                                                <StackLayout
                                                                    Padding="10,0,0,0"
                                                                    HorizontalOptions="FillAndExpand"
                                                                    Orientation="Horizontal"
                                                                    VerticalOptions="CenterAndExpand">
                                                                    <StackLayout
                                                                        HorizontalOptions="Start"
                                                                        VerticalOptions="CenterAndExpand"
                                                                        WidthRequest="{OnIdiom Phone='40',
                                                                                               Tablet='60'}">
                                                                        <Image
                                                                            Margin="0,0,10,0"
                                                                            HeightRequest="{OnIdiom Phone='30',
                                                                                                    Tablet='40'}"
                                                                            Source="{Binding ImageSrcSignalStrength}"
                                                                            WidthRequest="{OnIdiom Phone='30',
                                                                                                   Tablet='40'}" />
                                                                    </StackLayout>
                                                                    <StackLayout HorizontalOptions="FillAndExpand" VerticalOptions="CenterAndExpand">
                                                                        <Label
                                                                            FontSize="{OnIdiom Phone='18',
                                                                                               Tablet='20'}"
                                                                            Text="{Binding DeviceName}"
                                                                            TextColor="#333333" />
                                                                        <Label
                                                                            FontSize="{OnIdiom Phone='14',
                                                                                               Tablet='16'}"
                                                                            Text="{Binding DeviceDetail}"
                                                                            TextColor="Black" />
                                                                    </StackLayout>
                                                                    <StackLayout
                                                                        Margin="0,0,10,0"
                                                                        HorizontalOptions="End"
                                                                        Orientation="Horizontal"
                                                                        Spacing="0">
                                                                        <StackLayout
                                                                            HorizontalOptions="End"
                                                                            IsVisible="{Binding IsRestore}"
                                                                            Orientation="Horizontal"
                                                                            Spacing="7">
                                                                            <Frame
                                                                                Margin="0,0,0,0"
                                                                                Padding="7"
                                                                                BackgroundColor="#39B54A"
                                                                                ClassId="{Binding MacAddress}"
                                                                                CornerRadius="7"
                                                                                HorizontalOptions="EndAndExpand"
                                                                                VerticalOptions="Center">
                                                                                <StackLayout
                                                                                    HorizontalOptions="Fill"
                                                                                    Orientation="Horizontal"
                                                                                    Spacing="2"
                                                                                    VerticalOptions="CenterAndExpand">
                                                                                    <Image
                                                                                        HeightRequest="20"
                                                                                        Source="restore.png"
                                                                                        WidthRequest="20" />
                                                                                    <Label
                                                                                        Padding="0"
                                                                                        FontAttributes="Bold"
                                                                                        FontSize="15"
                                                                                        Text="Restore"
                                                                                        TextColor="White"
                                                                                        VerticalOptions="CenterAndExpand" />
                                                                                </StackLayout>
                                                                                <Frame.GestureRecognizers>
                                                                                    <TapGestureRecognizer Tapped="frmRestoreDefault_Tapped" />
                                                                                </Frame.GestureRecognizers>
                                                                            </Frame>
                                                                            <Frame
                                                                                Margin="0,0,0,0"
                                                                                Padding="7"
                                                                                BackgroundColor="#F99C00"
                                                                                ClassId="{Binding MacAddress}"
                                                                                CornerRadius="7"
                                                                                HorizontalOptions="EndAndExpand"
                                                                                VerticalOptions="Center">
                                                                                <StackLayout
                                                                                    HorizontalOptions="Fill"
                                                                                    Orientation="Horizontal"
                                                                                    VerticalOptions="CenterAndExpand">
                                                                                    <Label
                                                                                        Padding="0"
                                                                                        FontAttributes="Bold"
                                                                                        FontSize="15"
                                                                                        Text="PIN?"
                                                                                        TextColor="White"
                                                                                        VerticalOptions="CenterAndExpand" />
                                                                                </StackLayout>
                                                                                <Frame.GestureRecognizers>
                                                                                    <TapGestureRecognizer Tapped="frmForgotPIN_Tapped" />
                                                                                </Frame.GestureRecognizers>
                                                                            </Frame>
                                                                        </StackLayout>
                                                                        <StackLayout
                                                                            HorizontalOptions="End"
                                                                            IsVisible="{Binding IsVisible}"
                                                                            VerticalOptions="CenterAndExpand">
                                                                            <input:CheckBox
                                                                                x:Name="{Binding MacAddress}"
                                                                                Padding="2,0,2,0"
                                                                                BorderColor="#fc0"
                                                                                CheckChanged="CheckBox_CheckChanged"
                                                                                ClassId="{Binding MacAddress}"
                                                                                HeightRequest="35"
                                                                                HorizontalOptions="End"
                                                                                IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                                                ScaleX="{OnIdiom Phone='1.3',
                                                                                                 Tablet='1.5'}"
                                                                                ScaleY="{OnIdiom Phone='1.3',
                                                                                                 Tablet='1.5'}"
                                                                                Type="Regular"
                                                                                VerticalOptions="EndAndExpand"
                                                                                WidthRequest="35"
                                                                                Color="#fc0" />
                                                                        </StackLayout>
                                                                    </StackLayout>
                                                                </StackLayout>
                                                            </ViewCell.View>
                                                        </ViewCell>
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>
                                            <Label
                                                x:Name="lblNoDeviceListFound"
                                                Margin="0,20,0,0"
                                                FontAttributes="Bold"
                                                HorizontalOptions="CenterAndExpand"
                                                IsVisible="False"
                                                Style="{StaticResource NormalStyle}"
                                                Text="No devices found"
                                                TextColor="Red"
                                                VerticalOptions="FillAndExpand" />
                                        </StackLayout>

                                        <!--  Virtual Battery  -->
                                        <StackLayout
                                            x:Name="stackVirtualBatteryList"
                                            IsVisible="False"
                                            VerticalOptions="FillAndExpand">
                                            <ListView
                                                x:Name="lstVirtualBatteryList"
                                                Margin="0"
                                                BackgroundColor="White"
                                                IsVisible="False"
                                                RowHeight="70"
                                                Scrolled="lstVirtualBatteryList_Scrolled"
                                                SelectionMode="None"
                                                SeparatorVisibility="None"
                                                VerticalOptions="FillAndExpand"
                                                VerticalScrollBarVisibility="Always">
                                                <ListView.ItemTemplate>
                                                    <DataTemplate>
                                                        <ViewCell>
                                                            <ViewCell.View>
                                                                <StackLayout
                                                                    Padding="10,0,0,0"
                                                                    HorizontalOptions="FillAndExpand"
                                                                    Orientation="Horizontal"
                                                                    VerticalOptions="CenterAndExpand">
                                                                    <StackLayout
                                                                        Margin="0,16,0,0"
                                                                        HorizontalOptions="Start"
                                                                        VerticalOptions="CenterAndExpand">
                                                                        <Label
                                                                            FontSize="18"
                                                                            Text="{Binding DeviceName}"
                                                                            TextColor="#333333" />
                                                                        <Label
                                                                            FontSize="14"
                                                                            Text="{Binding DeviceDetail}"
                                                                            TextColor="Black" />
                                                                    </StackLayout>
                                                                    <StackLayout
                                                                        HorizontalOptions="EndAndExpand"
                                                                        IsVisible="{Binding IsVisible}"
                                                                        VerticalOptions="CenterAndExpand">
                                                                        <input:CheckBox
                                                                            Padding="2,0,2,0"
                                                                            BorderColor="#fc0"
                                                                            CheckChanged="CheckBox_CheckChanged"
                                                                            ClassId="{Binding MacAddress}"
                                                                            HorizontalOptions="EndAndExpand"
                                                                            IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                                            ScaleX="{OnIdiom Phone='1.3',
                                                                                             Tablet='1.5'}"
                                                                            ScaleY="{OnIdiom Phone='1.3',
                                                                                             Tablet='1.5'}"
                                                                            Type="Regular"
                                                                            VerticalOptions="EndAndExpand"
                                                                            Color="#fc0" />
                                                                    </StackLayout>
                                                                </StackLayout>
                                                            </ViewCell.View>
                                                        </ViewCell>
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>
                                            <Label
                                                x:Name="lblNoVirtualBatteryFound"
                                                Margin="0,20,0,0"
                                                FontAttributes="Bold"
                                                HorizontalOptions="CenterAndExpand"
                                                IsVisible="False"
                                                Style="{StaticResource NormalStyle}"
                                                Text="No virtual battery found"
                                                TextColor="Red"
                                                VerticalOptions="FillAndExpand" />
                                        </StackLayout>
                                    </StackLayout>
                                </Border>
                            </StackLayout>
                        </Border>
                    </StackLayout>
                </StackLayout>

                <Grid
                    x:Name="stackButtons"
                    HorizontalOptions="End"
                    VerticalOptions="FillAndExpand">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="130" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Image
                        x:Name="imgBatteryScanHorizontal"
                        Grid.Row="0"
                        Margin="{OnIdiom Phone='0,10,0,0',
                                         Tablet='0,20,0,0'}"
                        BackgroundColor="Transparent"
                        HorizontalOptions="FillAndExpand"
                        IsVisible="True"
                        MaximumHeightRequest="{OnIdiom Phone='70',
                                                       Tablet='120'}"
                        Source="scanbatteryicon.png"
                        VerticalOptions="FillAndExpand" />

                    <Grid
                        x:Name="stackClickableLinkMain"
                        Grid.Row="1"
                        Margin="10,5,10,0"
                        Padding="0,0,0,0"
                        HorizontalOptions="Fill"
                        RowSpacing="0"
                        VerticalOptions="FillAndExpand">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Label
                            x:Name="lblViewAllDevices"
                            Grid.Row="1"
                            FontAttributes="Bold"
                            FontSize="{OnIdiom Phone='19',
                                               Tablet='21'}"
                            HorizontalOptions="CenterAndExpand"
                            HorizontalTextAlignment="Center"
                            IsVisible="False"
                            Text="View All Devices"
                            TextColor="#1986fc"
                            TextDecorations="None"
                            VerticalOptions="EndAndExpand">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer NumberOfTapsRequired="1" Tapped="ViewAllDevicesTapped" />
                            </Label.GestureRecognizers>
                        </Label>
                        <StackLayout
                            x:Name="stackClickableLink"
                            Grid.Row="0"
                            Margin="5,0,5,5"
                            HorizontalOptions="Fill"
                            Orientation="Horizontal"
                            Spacing="20"
                            VerticalOptions="End">
                            <Label
                                x:Name="lblPrivacyPolicy"
                                FontAttributes="Bold"
                                FontSize="{OnIdiom Phone='19',
                                                   Tablet='21'}"
                                HorizontalOptions="EndAndExpand"
                                HorizontalTextAlignment="Center"
                                Text="Privacy Policy"
                                TextColor="#1986fc"
                                TextDecorations="None"
                                VerticalOptions="End"
                                VerticalTextAlignment="End">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer NumberOfTapsRequired="1" Tapped="onPrivacyTapped" />
                                </Label.GestureRecognizers>
                            </Label>
                            <Label
                                x:Name="lblClearCache"
                                FontAttributes="Bold"
                                FontSize="{OnIdiom Phone='19',
                                                   Tablet='21'}"
                                HorizontalOptions="StartAndExpand"
                                HorizontalTextAlignment="Center"
                                Text="Clear Cache"
                                TextColor="#1986fc"
                                TextDecorations="None"
                                VerticalOptions="End"
                                VerticalTextAlignment="End">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer NumberOfTapsRequired="1" Tapped="ClearDeviceDataTapped" />
                                </Label.GestureRecognizers>
                            </Label>
                        </StackLayout>
                    </Grid>

                    <Grid
                        x:Name="grdButtonInner"
                        Grid.Row="2"
                        Margin="15,5,15,20"
                        HorizontalOptions="FillAndExpand"
                        RowSpacing="10"
                        VerticalOptions="FillAndExpand">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border
                            x:Name="btnRemoteSupportNew"
                            Grid.Row="0"
                            Margin="0,0,0,0"
                            BackgroundColor="#4E6DEC"
                            HeightRequest="{OnIdiom Phone='45',
                                                    Tablet='55'}"
                            HorizontalOptions="FillAndExpand"
                            Stroke="#4E6DEC"
                            VerticalOptions="FillAndExpand">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <StackLayout
                                x:Name="grdRemoteButtonNew"
                                Padding="10"
                                HorizontalOptions="CenterAndExpand"
                                Orientation="Horizontal"
                                Spacing="7"
                                VerticalOptions="CenterAndExpand">
                                <Image
                                    x:Name="imgRemoteNew"
                                    HorizontalOptions="Center"
                                    Source="remotesupport.png"
                                    Style="{StaticResource ScanPageImgSize}"
                                    VerticalOptions="CenterAndExpand" />
                                <Label
                                    x:Name="lblRemoteNew"
                                    Margin="0,0,0,0"
                                    Padding="0,0,5,0"
                                    HorizontalOptions="Center"
                                    Style="{StaticResource ScanPageFont}"
                                    Text="End Remote Support"
                                    TextColor="White"
                                    VerticalOptions="FillAndExpand"
                                    VerticalTextAlignment="Center" />
                            </StackLayout>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer NumberOfTapsRequired="1" Tapped="btnEndRemoteSupprt_Tapped" />
                            </Border.GestureRecognizers>
                        </Border>

                        <StackLayout
                            x:Name="stackButtonInner"
                            Grid.Row="1"
                            Orientation="Horizontal"
                            Spacing="{OnIdiom Phone='7',
                                              Tablet='15'}"
                            VerticalOptions="FillAndExpand">
                            <Border
                                x:Name="btnScanNew"
                                Margin="0,0,0,0"
                                BackgroundColor="#F99C00"
                                HeightRequest="{OnIdiom Phone='70',
                                                        Tablet='55'}"
                                HorizontalOptions="FillAndExpand"
                                Stroke="#F99C00"
                                VerticalOptions="FillAndExpand">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10" />
                                </Border.StrokeShape>
                                <StackLayout
                                    x:Name="grdScanButtonNew"
                                    Padding="10"
                                    HorizontalOptions="CenterAndExpand"
                                    Orientation="{OnIdiom Phone='Vertical',
                                                          Tablet='Horizontal'}"
                                    Spacing="5"
                                    VerticalOptions="CenterAndExpand">
                                    <Image
                                        x:Name="imgScanNew"
                                        HorizontalOptions="Center"
                                        Source="scanbattery.png"
                                        Style="{StaticResource ScanPageImgSize}"
                                        VerticalOptions="CenterAndExpand" />
                                    <Label
                                        x:Name="lblScanNew"
                                        Margin="0,0,0,0"
                                        Padding="0,0,5,0"
                                        HorizontalOptions="Center"
                                        Style="{StaticResource ScanPageFont}"
                                        Text="Scan"
                                        TextColor="White"
                                        VerticalOptions="FillAndExpand"
                                        VerticalTextAlignment="Center" />
                                </StackLayout>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer NumberOfTapsRequired="1" Tapped="btnScan_Clicked" />
                                </Border.GestureRecognizers>
                            </Border>

                            <Border
                                x:Name="btnConnectNew"
                                Margin="0,0,0,0"
                                BackgroundColor="#14B729"
                                HeightRequest="{OnIdiom Phone='70',
                                                        Tablet='55'}"
                                HorizontalOptions="FillAndExpand"
                                Stroke="#14B729"
                                VerticalOptions="FillAndExpand">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10" />
                                </Border.StrokeShape>
                                <StackLayout
                                    x:Name="grdConnectButtonNew"
                                    Padding="10"
                                    HorizontalOptions="CenterAndExpand"
                                    Orientation="{OnIdiom Phone='Vertical',
                                                          Tablet='Horizontal'}"
                                    Spacing="5"
                                    VerticalOptions="CenterAndExpand">
                                    <Image
                                        x:Name="imgConnectNew"
                                        HorizontalOptions="Center"
                                        Source="connectbattery.png"
                                        Style="{StaticResource ScanPageImgSize}"
                                        VerticalOptions="CenterAndExpand" />
                                    <Label
                                        x:Name="lblConnectNew"
                                        Margin="0,0,0,0"
                                        Padding="0,0,5,0"
                                        HorizontalOptions="Center"
                                        Style="{StaticResource ScanPageFont}"
                                        Text="Connect"
                                        TextColor="White"
                                        VerticalOptions="FillAndExpand"
                                        VerticalTextAlignment="Center" />
                                </StackLayout>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer NumberOfTapsRequired="1" Tapped="btnConnect_Clicked" />
                                </Border.GestureRecognizers>
                            </Border>

                            <Border
                                x:Name="btnQuitNew"
                                Margin="0,0,0,0"
                                BackgroundColor="#DC2624"
                                HeightRequest="{OnIdiom Phone='70',
                                                        Tablet='55'}"
                                HorizontalOptions="FillAndExpand"
                                Stroke="#DC2624"
                                VerticalOptions="FillAndExpand">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10" />
                                </Border.StrokeShape>
                                <StackLayout
                                    x:Name="grdQuitButtonNew"
                                    Padding="10"
                                    HorizontalOptions="CenterAndExpand"
                                    Orientation="{OnIdiom Phone='Vertical',
                                                          Tablet='Horizontal'}"
                                    Spacing="5"
                                    VerticalOptions="CenterAndExpand">
                                    <Image
                                        x:Name="imgQuitNew"
                                        HorizontalOptions="Center"
                                        Source="quiteapplication.png"
                                        Style="{StaticResource ScanPageImgSize}"
                                        VerticalOptions="FillAndExpand" />
                                    <Label
                                        x:Name="lblQuitNew"
                                        Margin="0,0,0,0"
                                        Padding="0,0,5,0"
                                        HorizontalOptions="Center"
                                        Style="{StaticResource ScanPageFont}"
                                        Text="Quit"
                                        TextColor="White"
                                        VerticalOptions="FillAndExpand"
                                        VerticalTextAlignment="Center" />
                                </StackLayout>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer NumberOfTapsRequired="1" Tapped="btnQuite_Clicked" />
                                </Border.GestureRecognizers>
                            </Border>
                        </StackLayout>
                    </Grid>
                </Grid>
            </StackLayout>

        </Grid>

        <!--  Other Design Part Start  -->
        <StackLayout
            x:Name="stkBusy"
            BackgroundColor="#000000"
            HorizontalOptions="FillAndExpand"
            InputTransparent="False"
            IsVisible="False"
            Opacity="0.6"
            VerticalOptions="FillAndExpand"
            ZIndex="98">
            <StackLayout.GestureRecognizers>
                <TapGestureRecognizer />
            </StackLayout.GestureRecognizers>
        </StackLayout>
        <Border
            x:Name="sfbIsBusyIndicator"
            BackgroundColor="#fff"
            HeightRequest="260"
            HorizontalOptions="CenterAndExpand"
            IsVisible="False"
            Stroke="White"
            VerticalOptions="CenterAndExpand"
            WidthRequest="280"
            ZIndex="99">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
            </Border.StrokeShape>
            <StackLayout
                HorizontalOptions="Center"
                Spacing="10"
                VerticalOptions="Center">
                <Image
                    x:Name="loadingImage"
                    HeightRequest="150"
                    HorizontalOptions="Center"
                    IsAnimationPlaying="True"
                    Source="loading.gif"
                    VerticalOptions="Center"
                    WidthRequest="150" />
                <!--  Label for Title  -->
                <Label
                    x:Name="lblBusyIndicator"
                    Margin="0,-20,0,0"
                    HorizontalOptions="CenterAndExpand"
                    HorizontalTextAlignment="Center"
                    Style="{StaticResource BusyIndicatorStyle}"
                    Text="Updating..."
                    TextColor="#F0C000"
                    VerticalOptions="Center" />
            </StackLayout>
        </Border>
        <Border
            x:Name="btnCancelAutoConnect"
            Margin="0,0,0,30"
            Padding="10,0,0,0"
            BackgroundColor="#DC2624"
            HorizontalOptions="CenterAndExpand"
            IsVisible="false"
            Stroke="#DC2624"
            VerticalOptions="EndAndExpand"
            ZIndex="99">
