<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SFKBle_Admin.DeviceDetails"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:ListCollection="clr-namespace:System.Collections.Generic;assembly=netstandard"
    xmlns:Local="clr-namespace:SFKBle_Admin"
    xmlns:buttons="clr-namespace:Syncfusion.Maui.Buttons;assembly=Syncfusion.Maui.Buttons"
    xmlns:chart="clr-namespace:Syncfusion.Maui.Charts;assembly=Syncfusion.Maui.Charts"
    xmlns:combobox="clr-namespace:Syncfusion.Maui.Inputs;assembly=Syncfusion.Maui.Inputs"
    xmlns:core="clr-namespace:Syncfusion.Maui.Core;assembly=Syncfusion.Maui.Core"
    xmlns:gauge="clr-namespace:Syncfusion.Maui.Gauges;assembly=Syncfusion.Maui.Gauges"
    xmlns:input="clr-namespace:InputKit.Shared.Controls;assembly=InputKit.Maui"
    xmlns:pinview="clr-namespace:PINView.Maui;assembly=PINView.Maui"
    xmlns:progressBar="clr-namespace:Syncfusion.Maui.ProgressBar;assembly=Syncfusion.Maui.ProgressBar"
    xmlns:range="clr-namespace:Syncfusion.Maui.Sliders;assembly=Syncfusion.Maui.Sliders"
    xmlns:segmentCollection="clr-namespace:System.Collections.Generic;assembly=netstandard"
    xmlns:syncfusion="clr-namespace:Syncfusion.Maui.ListView;assembly=Syncfusion.Maui.ListView"
    xmlns:tabView="clr-namespace:Syncfusion.Maui.TabView;assembly=Syncfusion.Maui.TabView"
    xmlns:xct="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    NavigationPage.HasNavigationBar="False">

    <ContentPage.BindingContext>
        <Local:CellViewModel />
    </ContentPage.BindingContext>

    <Grid>
        <StackLayout BackgroundColor="#ffffff">
            <StackLayout
                x:Name="stackHeader"
                BackgroundColor="White"
                HeightRequest="40"
                HorizontalOptions="FillAndExpand"
                Orientation="Vertical"
                VerticalOptions="Start">
                <StackLayout
                    Padding="5,5,5,5"
                    HorizontalOptions="FillAndExpand"
                    Orientation="Horizontal"
                    VerticalOptions="FillAndExpand">
                    <Image Source="sunfunkitslogowtb.png" WidthRequest="70" />
                    <Label
                        Padding="10,0,0,0"
                        FontAttributes="Bold"
                        FontSize="15"
                        HorizontalOptions="CenterAndExpand"
                        IsVisible="False"
                        Text="www.sunfunkits.com"
                        TextColor="Black" />
                    <Label
                        FontSize="15"
                        HorizontalOptions="FillAndExpand"
                        HorizontalTextAlignment="End"
                        Text="V9.38"
                        TextColor="Black"
                        VerticalOptions="Center" />
                </StackLayout>
                <BoxView
                    BackgroundColor="#f0c000"
                    HeightRequest="1"
                    HorizontalOptions="FillAndExpand"
                    VerticalOptions="Start" />
            </StackLayout>

            <tabView:SfTabView
                x:Name="SKFTabView"
                EnableSwiping="False"
                IndicatorBackground="#F0C000"
                IndicatorPlacement="Top"
                IndicatorWidthMode="Stretch"
                IsEnabled="True"
                IsScrollButtonEnabled="True"
                SelectionChanged="SKFTabView_SelectionChanged"
                TabBarHeight="70"
                TabBarPlacement="Bottom"
                TabWidthMode="Default"
                VerticalOptions="FillAndExpand">
                <tabView:SfTabItem
                    x:Name="Scan"
                    FontSize="16"
                    ImagePosition="Top"
                    ImageSource="scanicon.png"
                    Scale="1.5">
                    <tabView:SfTabItem.Content>
                        <StackLayout />
                    </tabView:SfTabItem.Content>
                </tabView:SfTabItem>
                <tabView:SfTabItem
                    x:Name="Home"
                    FontSize="16"
                    ImagePosition="Top"
                    ImageSource="homeicon.png"
                    Scale="1.5"
                    TextColor="#F0C000">
                    <tabView:SfTabItem.Content>
                        <StackLayout
                            x:Name="gridMainTabOuter"
                            Margin="15"
                            BackgroundColor="White"
                            HorizontalOptions="FillAndExpand"
                            Orientation="Horizontal"
                            VerticalOptions="FillAndExpand">
                            <ScrollView
                                x:Name="scrMainTab"
                                HorizontalOptions="FillAndExpand"
                                IsEnabled="True"
                                IsVisible="true"
                                VerticalOptions="FillAndExpand"
                                VerticalScrollBarVisibility="Never">
                                <StackLayout
                                    x:Name="stackHomeTabInner"
                                    BackgroundColor="White"
                                    HorizontalOptions="FillAndExpand"
                                    Orientation="Vertical"
                                    VerticalOptions="FillAndExpand">
                                    <StackLayout
                                        x:Name="stackGaugeMainStack"
                                        Margin="0,0,0,5"
                                        HorizontalOptions="Fill"
                                        Orientation="Vertical"
                                        VerticalOptions="Start">
                                        <StackLayout
                                            x:Name="stackGaugeMainStackInner"
                                            HorizontalOptions="FillAndExpand"
                                            Orientation="Horizontal"
                                            VerticalOptions="Start">
                                            <StackLayout
                                                x:Name="stackFirstMain"
                                                Margin="5,0,0,0"
                                                HorizontalOptions="FillAndExpand"
                                                IsVisible="True"
                                                Orientation="Vertical"
                                                VerticalOptions="FillAndExpand">
                                                <StackLayout
                                                    x:Name="stackBMSIndicators"
                                                    HeightRequest="0"
                                                    HorizontalOptions="Start"
                                                    Orientation="Horizontal"
                                                    Style="{StaticResource HomePageIndicatorSize}"
                                                    VerticalOptions="Start"
                                                    WidthRequest="30">
                                                    <Image
                                                        x:Name="imgUpdateIconForDevice"
                                                        Margin="{OnIdiom Phone='10,0,0,0',
                                                                         Tablet='0,0,0,0'}"
                                                        HorizontalOptions="StartAndExpand"
                                                        IsVisible="True"
                                                        Source="update.png"
                                                        Style="{StaticResource UpdateIconSize}"
                                                        VerticalOptions="StartAndExpand" />
                                                    <Image
                                                        x:Name="imgFailIconForDevice"
                                                        Margin="{OnIdiom Phone='10,0,0,0',
                                                                         Tablet='0,0,0,0'}"
                                                        HorizontalOptions="StartAndExpand"
                                                        IsVisible="false"
                                                        Source="failedupdates.png"
                                                        Style="{StaticResource UpdateIconSize}"
                                                        VerticalOptions="StartAndExpand" />
                                                </StackLayout>
                                                <StackLayout
                                                    x:Name="stackBatteryStaus"
                                                    HorizontalOptions="Fill"
                                                    VerticalOptions="FillAndExpand">
                                                    <StackLayout
                                                        x:Name="stackBatteryPercentage"
                                                        Margin="{OnIdiom Phone='0,5,0,25',
                                                                         Tablet='0,10,0,25'}"
                                                        BackgroundColor="Transparent"
                                                        HorizontalOptions="Center"
                                                        Orientation="Vertical"
                                                        Spacing="0"
                                                        VerticalOptions="Start">
                                                        <StackLayout HorizontalOptions="FillAndExpand" VerticalOptions="FillAndExpand">
                                                            <Label
                                                                x:Name="lblBatteryStatusPercent"
                                                                Padding="0,0,0,0"
                                                                FontAttributes="Bold"
                                                                FontSize="65"
                                                                HorizontalOptions="CenterAndExpand"
                                                                HorizontalTextAlignment="Center"
                                                                Style="{StaticResource SOCFontSize}"
                                                                Text="0%"
                                                                TextColor="Black"
                                                                VerticalTextAlignment="Start" />
                                                            <StackLayout x:Name="stackSOCModeMain" IsVisible="False">
                                                                <Image
                                                                    x:Name="imgMainTabAnotaion"
                                                                    Source="storagemodeicon.png"
                                                                    Style="{StaticResource SOCModeImage}" />
                                                                <Label
                                                                    x:Name="lblSOCMode"
                                                                    FontAttributes="Bold"
                                                                    HorizontalOptions="Center"
                                                                    Style="{StaticResource SOCModeLabel}"
                                                                    Text="Storage Mode"
                                                                    TextColor="Black" />
                                                            </StackLayout>
                                                        </StackLayout>
                                                        <StackLayout
                                                            x:Name="stackSinceFullChargeMainTab"
                                                            Margin="25,0,0,0"
                                                            HorizontalOptions="Start"
                                                            IsVisible="False"
                                                            Orientation="Horizontal"
                                                            VerticalOptions="CenterAndExpand">
                                                            <StackLayout Style="{StaticResource stackHomeMainStatus}">
                                                                <Frame
                                                                    x:Name="frmSinceFullChargeTab"
                                                                    Margin="7,0,7,0"
                                                                    Padding="10,0,10,0"
                                                                    BackgroundColor="#39B54A"
                                                                    BorderColor="Transparent"
                                                                    CornerRadius="5"
                                                                    HasShadow="False"
                                                                    HorizontalOptions="FillAndExpand"
                                                                    Style="{StaticResource frmHomeMainStatus}"
                                                                    VerticalOptions="StartAndExpand">
                                                                    <Grid Style="{StaticResource grdMainPageFullChargeDesign}">
                                                                        <Image
                                                                            HorizontalOptions="CenterAndExpand"
                                                                            Source="calender.png"
                                                                            Style="{StaticResource imgMainPageFullChargeDesign}"
                                                                            VerticalOptions="CenterAndExpand" />
                                                                        <StackLayout
                                                                            HorizontalOptions="FillAndExpand"
                                                                            Style="{StaticResource stackMainPageFullChargeDesign}"
                                                                            VerticalOptions="FillAndExpand">
                                                                            <Label
                                                                                x:Name="lblSinceFullChargeTab"
                                                                                FontAttributes="Bold"
                                                                                FontSize="22"
                                                                                HorizontalOptions="Center"
                                                                                Style="{StaticResource lblSinceFullChargeDays}"
                                                                                Text="0"
                                                                                TextColor="Black"
                                                                                VerticalOptions="CenterAndExpand" />
                                                                        </StackLayout>
                                                                    </Grid>
                                                                </Frame>
                                                            </StackLayout>
                                                        </StackLayout>
                                                    </StackLayout>
                                                </StackLayout>
                                            </StackLayout>

                                            <Border
                                                x:Name="brdHomeStatus"
                                                Margin="5,5,0,0"
                                                HorizontalOptions="FillAndExpand"
                                                Stroke="#444444"
                                                StrokeThickness="0"
                                                VerticalOptions="StartAndExpand">
                                                <StackLayout HorizontalOptions="FillAndExpand" VerticalOptions="Fill">
                                                    <StackLayout
                                                        x:Name="stackHomeStatusInnerTab"
                                                        HorizontalOptions="CenterAndExpand"
                                                        IsVisible="false"
                                                        Orientation="Horizontal"
                                                        VerticalOptions="StartAndExpand">
                                                        <Frame
                                                            x:Name="frmHomeChargeTab"
                                                            Margin="15,0,15,0"
                                                            Padding="10,0,10,0"
                                                            BackgroundColor="#39B54A"
                                                            BorderColor="Transparent"
                                                            CornerRadius="5"
                                                            HasShadow="False"
                                                            HorizontalOptions="FillAndExpand"
                                                            Style="{StaticResource frmHomeMainStatus}"
                                                            VerticalOptions="StartAndExpand">
                                                            <Image
                                                                x:Name="imgChargingEnableDisable"
                                                                HorizontalOptions="CenterAndExpand"
                                                                Source="homechargingicon.png"
                                                                Style="{StaticResource imgMainPageStatusDesign}"
                                                                VerticalOptions="CenterAndExpand" />
                                                        </Frame>

                                                        <Frame
                                                            x:Name="frmHomeDischargeTab"
                                                            Margin="15,0,15,0"
                                                            Padding="10,0,10,0"
                                                            BackgroundColor="#39B54A"
                                                            BorderColor="Transparent"
                                                            CornerRadius="5"
                                                            HasShadow="False"
                                                            HorizontalOptions="FillAndExpand"
                                                            Style="{StaticResource frmHomeMainStatus}"
                                                            VerticalOptions="StartAndExpand">
                                                            <Image
                                                                x:Name="imgDischargingEnableDisable"
                                                                HorizontalOptions="CenterAndExpand"
                                                                Source="homedischargingicon.png"
                                                                Style="{StaticResource imgMainPageStatusDesign}"
                                                                VerticalOptions="CenterAndExpand" />
                                                        </Frame>

                                                        <Frame
                                                            x:Name="frmHomeBatteryStatusTab"
                                                            Margin="15,0,15,0"
                                                            Padding="10,0,10,0"
                                                            BackgroundColor="#979797"
                                                            BorderColor="Transparent"
                                                            CornerRadius="5"
                                                            HasShadow="False"
                                                            HorizontalOptions="CenterAndExpand"
                                                            Style="{StaticResource frmHomeMainStatus}"
                                                            VerticalOptions="StartAndExpand">
                                                            <Image
                                                                x:Name="imgBatteryStatus"
                                                                HorizontalOptions="CenterAndExpand"
                                                                IsAnimationPlaying="True"
                                                                Source="standby.png"
                                                                Style="{StaticResource imgMainPageStatusDesign}"
                                                                VerticalOptions="FillAndExpand" />
                                                        </Frame>
                                                    </StackLayout>
                                                    <StackLayout
                                                        x:Name="stackCycleRemaing"
                                                        Margin="{OnIdiom Phone='10,5,0,0',
                                                                         Tablet='0,0,0,0'}"
                                                        HorizontalOptions="FillAndExpand"
                                                        Orientation="Vertical"
                                                        Spacing="10"
                                                        VerticalOptions="Fill">
                                                        <StackLayout
                                                            x:Name="stackRemaingAhMain"
                                                            Margin="0,0,0,0"
                                                            HorizontalOptions="FillAndExpand"
                                                            Orientation="Vertical"
                                                            VerticalOptions="StartAndExpand">
                                                            <Image
                                                                HorizontalOptions="Center"
                                                                Source="remaingah.png"
                                                                Style="{StaticResource imgCycleRemaingHeight}"
                                                                VerticalOptions="CenterAndExpand" />
                                                            <StackLayout
                                                                x:Name="stackRemainglabel"
                                                                Margin="{OnIdiom Phone='15,5,0,0',
                                                                                 Tablet='0,0,0,0'}"
                                                                HorizontalOptions="Fill"
                                                                Orientation="Vertical"
                                                                VerticalOptions="FillAndExpand">
                                                                <Label
                                                                    HorizontalOptions="CenterAndExpand"
                                                                    HorizontalTextAlignment="Center"
                                                                    IsVisible="{OnIdiom Phone='False',
                                                                                        Tablet='False'}"
                                                                    Style="{StaticResource lblCycleRemaingFontOne}"
                                                                    Text="Remaining"
                                                                    TextColor="#000"
                                                                    VerticalOptions="StartAndExpand"
                                                                    VerticalTextAlignment="Center" />
                                                                <Label
                                                                    x:Name="lblRemainingL"
                                                                    Margin="{OnIdiom Phone='0,5,0,0',
                                                                                     Tablet='0,5,0,0'}"
                                                                    FontAttributes="Bold"
                                                                    HorizontalOptions="CenterAndExpand"
                                                                    HorizontalTextAlignment="Center"
                                                                    Style="{StaticResource lblCycleRemaingFontTwo}"
                                                                    Text="0"
                                                                    TextColor="#000000"
                                                                    VerticalOptions="CenterAndExpand"
                                                                    VerticalTextAlignment="Center" />
                                                            </StackLayout>
                                                        </StackLayout>
                                                        <StackLayout
                                                            x:Name="stackCycleCountMain"
                                                            Margin="10,10,0,0"
                                                            HorizontalOptions="FillAndExpand"
                                                            Orientation="Vertical"
                                                            VerticalOptions="StartAndExpand">
                                                            <Image
                                                                HorizontalOptions="Center"
                                                                Source="cyclecount.png"
                                                                Style="{StaticResource imgCycleRemaingHeight}"
                                                                VerticalOptions="CenterAndExpand" />
                                                            <StackLayout
                                                                x:Name="stackCycleCountinner"
                                                                Margin="{OnIdiom Phone='10,5,0,0',
                                                                                 Tablet='0,0,0,0'}"
                                                                HorizontalOptions="Fill"
                                                                Orientation="Vertical"
                                                                VerticalOptions="FillAndExpand">
                                                                <Label
                                                                    HorizontalOptions="Center"
                                                                    HorizontalTextAlignment="Center"
                                                                    IsVisible="{OnIdiom Phone='False',
                                                                                        Tablet='False'}"
                                                                    Style="{StaticResource lblCycleRemaingFontOne}"
                                                                    Text="Cycle Count"
                                                                    TextColor="#000"
                                                                    VerticalOptions="StartAndExpand"
                                                                    VerticalTextAlignment="Center" />
                                                                <Label
                                                                    x:Name="lblCycleCount"
                                                                    Margin="{OnIdiom Phone='0,5,0,0',
                                                                                     Tablet='0,5,0,0'}"
                                                                    FontAttributes="Bold"
                                                                    HorizontalOptions="CenterAndExpand"
                                                                    HorizontalTextAlignment="Center"
                                                                    Style="{StaticResource lblCycleRemaingFontTwo}"
                                                                    Text="0"
                                                                    TextColor="#000000"
                                                                    VerticalOptions="CenterAndExpand"
                                                                    VerticalTextAlignment="Center" />
                                                            </StackLayout>
                                                        </StackLayout>
                                                    </StackLayout>
                                                </StackLayout>
                                            </Border>
                                        </StackLayout>

                                        <StackLayout
                                            x:Name="stackHomeStatusInnerMbl"
                                            Margin="10,5,0,15"
                                            HorizontalOptions="Start"
                                            IsVisible="True"
                                            Orientation="Horizontal"
                                            Spacing="5"
                                            VerticalOptions="StartAndExpand">
                                            <Frame
                                                x:Name="frmHomeChargeMbl"
                                                Margin="7,0,7,0"
                                                Padding="10,0,10,0"
                                                BackgroundColor="#39B54A"
                                                BorderColor="Transparent"
                                                CornerRadius="5"
                                                HasShadow="False"
                                                HorizontalOptions="FillAndExpand"
                                                Style="{StaticResource frmHomeMainStatus}"
                                                VerticalOptions="StartAndExpand">
                                                <Image
                                                    x:Name="imgChargingEnableDisableMbl"
                                                    HorizontalOptions="CenterAndExpand"
                                                    Source="homechargingicon.png"
                                                    Style="{StaticResource imgMainPageStatusDesign}"
                                                    VerticalOptions="CenterAndExpand" />
                                            </Frame>

                                            <Frame
                                                x:Name="frmHomeDischargeMbl"
                                                Margin="7,0,7,0"
                                                Padding="10,0,10,0"
                                                BackgroundColor="#39B54A"
                                                CornerRadius="5"
                                                HasShadow="False"
                                                HorizontalOptions="FillAndExpand"
                                                Style="{StaticResource frmHomeMainStatus}"
                                                VerticalOptions="StartAndExpand">
                                                <Image
                                                    x:Name="imgDischargingEnableDisableMbl"
                                                    HorizontalOptions="CenterAndExpand"
                                                    Source="homedischargingicon.png"
                                                    Style="{StaticResource imgMainPageStatusDesign}"
                                                    VerticalOptions="CenterAndExpand" />
                                            </Frame>

                                            <Frame
                                                x:Name="frmHomeBatteryStatusMbl"
                                                Margin="7,0,7,0"
                                                Padding="0"
                                                BackgroundColor="#979797"
                                                CornerRadius="5"
                                                HasShadow="False"
                                                HorizontalOptions="FillAndExpand"
                                                Style="{StaticResource frmHomeMainStatus}"
                                                VerticalOptions="StartAndExpand">
                                                <Image
                                                    x:Name="imgBatteryStatusMbl"
                                                    HorizontalOptions="CenterAndExpand"
                                                    IsAnimationPlaying="True"
                                                    Source="standby.png"
                                                    Style="{StaticResource imgMainPageStatusDesign}"
                                                    VerticalOptions="CenterAndExpand" />
                                            </Frame>

                                            <StackLayout
                                                x:Name="stackSinceFullChargeMainMBL"
                                                Margin="10,0,0,0"
                                                HorizontalOptions="StartAndExpand"
                                                IsVisible="False"
                                                Orientation="Horizontal"
                                                VerticalOptions="CenterAndExpand">
                                                <StackLayout Style="{StaticResource stackHomeMainStatus}">
                                                    <Frame
                                                        x:Name="frmSinceFullChargeMbl"
                                                        Margin="0,0,7,0"
                                                        Padding="10,0,10,0"
                                                        BackgroundColor="#39B54A"
                                                        CornerRadius="5"
                                                        HasShadow="False"
                                                        HorizontalOptions="FillAndExpand"
                                                        Style="{StaticResource frmHomeMainStatus}"
                                                        VerticalOptions="StartAndExpand">
                                                        <Grid Style="{StaticResource grdMainPageFullChargeDesign}">
                                                            <Image
                                                                x:Name="imgSinceFullChargeMBL"
                                                                HeightRequest="35"
                                                                HorizontalOptions="CenterAndExpand"
                                                                Source="calender.png"
                                                                Style="{StaticResource imgMainPageFullChargeDesign}"
                                                                VerticalOptions="CenterAndExpand"
                                                                WidthRequest="35" />
                                                            <StackLayout
                                                                HorizontalOptions="FillAndExpand"
                                                                Style="{StaticResource stackMainPageFullChargeDesign}"
                                                                VerticalOptions="FillAndExpand">
                                                                <Label
                                                                    x:Name="lblSinceFullChargeMBL"
                                                                    FontAttributes="Bold"
                                                                    HorizontalOptions="Center"
                                                                    Style="{StaticResource lblSinceFullChargeDays}"
                                                                    Text="0"
                                                                    TextColor="Black"
                                                                    VerticalOptions="CenterAndExpand" />
                                                            </StackLayout>
                                                        </Grid>
                                                    </Frame>
                                                </StackLayout>
                                            </StackLayout>
                                        </StackLayout>
                                    </StackLayout>
                                    <StackLayout
                                        x:Name="MainStackTwo"
                                        HorizontalOptions="FillAndExpand"
                                        Orientation="Vertical"
                                        VerticalOptions="StartAndExpand">
                                        <StackLayout
                                            x:Name="stackBMSDetails"
                                            Margin="25,50,0,15"
                                            HorizontalOptions="FillAndExpand"
                                            Style="{StaticResource stackBMSDetailsOuter}"
                                            VerticalOptions="StartAndExpand">
                                            <StackLayout
                                                Margin="0,0,0,20"
                                                HorizontalOptions="Fill"
                                                Style="{StaticResource stackBMSDetailsInner}"
                                                VerticalOptions="StartAndExpand">
                                                <StackLayout Style="{StaticResource stackBMSDetailsPerStackOuter}" VerticalOptions="CenterAndExpand">
                                                    <Image
                                                        Source="voltsicon.png"
                                                        Style="{StaticResource imgBMSDetailsLabelIcon}"
                                                        VerticalOptions="StartAndExpand" />
                                                    <StackLayout Orientation="Vertical" Style="{StaticResource stackBMSDetailsPerStackInner}">
                                                        <Label
                                                            Padding="0"
                                                            Style="{StaticResource lblBMSDetailsLabelHeading}"
                                                            Text="Volts"
                                                            TextColor="#090909"
                                                            VerticalOptions="StartAndExpand" />
                                                        <Label
                                                            x:Name="lblpackVL"
                                                            FontAttributes="Bold"
                                                            Style="{StaticResource lblBMSDetailsLabelValue}"
                                                            Text="0.0"
                                                            TextColor="#090909" />
                                                    </StackLayout>
                                                </StackLayout>

                                                <StackLayout Style="{StaticResource stackBMSDetailsPerStackOuter}" VerticalOptions="CenterAndExpand">
                                                    <Image
                                                        Source="ampsicon.png"
                                                        Style="{StaticResource imgBMSDetailsLabelIcon}"
                                                        VerticalOptions="StartAndExpand" />
                                                    <StackLayout Orientation="Vertical" Style="{StaticResource stackBMSDetailsPerStackInner}">
                                                        <Label
                                                            Style="{StaticResource lblBMSDetailsLabelHeading}"
                                                            Text="Amps"
                                                            TextColor="#090909"
                                                            VerticalOptions="StartAndExpand" />
                                                        <Label
                                                            x:Name="lblAmpsL"
                                                            FontAttributes="Bold"
                                                            Style="{StaticResource lblBMSDetailsLabelValue}"
                                                            Text="0.0"
                                                            TextColor="#090909" />
                                                    </StackLayout>
                                                </StackLayout>

                                                <StackLayout Style="{StaticResource stackBMSDetailsPerStackOuter}" VerticalOptions="CenterAndExpand">
                                                    <Image
                                                        Source="wattsicon.png"
                                                        Style="{StaticResource imgBMSDetailsLabelIcon}"
                                                        VerticalOptions="StartAndExpand" />
                                                    <StackLayout Orientation="Vertical" Style="{StaticResource stackBMSDetailsPerStackInner}">
                                                        <Label
                                                            Style="{StaticResource lblBMSDetailsLabelHeading}"
                                                            Text="Watts"
                                                            TextColor="#090909"
                                                            VerticalOptions="StartAndExpand" />
                                                        <Label
                                                            x:Name="lblWattsL"
                                                            FontAttributes="Bold"
                                                            Style="{StaticResource lblBMSDetailsLabelValue}"
                                                            Text="0.0"
                                                            TextColor="#090909" />
                                                    </StackLayout>
                                                </StackLayout>
                                            </StackLayout>

                                            <StackLayout
                                                Margin="0,0,0,20"
                                                HorizontalOptions="FillAndExpand"
                                                Style="{StaticResource stackBMSDetailsInner}"
                                                VerticalOptions="StartAndExpand">
                                                <StackLayout Style="{StaticResource stackBMSDetailsPerStackOuter}" VerticalOptions="CenterAndExpand">
                                                    <Image
                                                        Source="bmstemp.png"
                                                        Style="{StaticResource imgBMSDetailsLabelIcon}"
                                                        VerticalOptions="StartAndExpand" />
                                                    <StackLayout Orientation="Vertical" Style="{StaticResource stackBMSDetailsPerStackInner}">
                                                        <Label
                                                            Style="{StaticResource lblBMSDetailsLabelHeading}"
                                                            Text="BMS T."
                                                            TextColor="#090909"
                                                            VerticalOptions="StartAndExpand" />
                                                        <Label
                                                            x:Name="lblTempreatureL"
                                                            FontAttributes="Bold"
                                                            Style="{StaticResource lblBMSDetailsLabelValue}"
                                                            Text="0.0"
                                                            TextColor="#090909" />
                                                    </StackLayout>
                                                </StackLayout>

                                                <StackLayout Style="{StaticResource stackBMSDetailsPerStackOuter}" VerticalOptions="CenterAndExpand">
                                                    <Image
                                                        Source="casetemp1.png"
                                                        Style="{StaticResource imgBMSDetailsLabelIcon}"
                                                        VerticalOptions="StartAndExpand" />
                                                    <StackLayout Orientation="Vertical" Style="{StaticResource stackBMSDetailsPerStackInner}">
                                                        <Label
                                                            Style="{StaticResource lblBMSDetailsLabelHeading}"
                                                            Text="Case T. 1"
                                                            TextColor="#090909"
                                                            VerticalOptions="StartAndExpand" />
                                                        <Label
                                                            x:Name="lblTempreature2L"
                                                            FontAttributes="Bold"
                                                            Style="{StaticResource lblBMSDetailsLabelValue}"
                                                            Text="0"
                                                            TextColor="#090909" />
                                                    </StackLayout>
                                                </StackLayout>

                                                <StackLayout Style="{StaticResource stackBMSDetailsPerStackOuter}" VerticalOptions="CenterAndExpand">
                                                    <Image
                                                        Source="casetemp2.png"
                                                        Style="{StaticResource imgBMSDetailsLabelIcon}"
                                                        VerticalOptions="StartAndExpand" />
                                                    <StackLayout Orientation="Vertical" Style="{StaticResource stackBMSDetailsPerStackInner}">
                                                        <Label
                                                            HorizontalOptions="StartAndExpand"
                                                            Style="{StaticResource lblBMSDetailsLabelHeading}"
                                                            Text="Case T. 2"
                                                            TextColor="#090909"
                                                            VerticalOptions="StartAndExpand" />
                                                        <Label
                                                            x:Name="lblTempreature3L"
                                                            FontAttributes="Bold"
                                                            Style="{StaticResource lblBMSDetailsLabelValue}"
                                                            Text="0"
                                                            TextColor="#090909" />
                                                    </StackLayout>
                                                </StackLayout>

                                            </StackLayout>

                                            <StackLayout
                                                x:Name="NF_StackHomeIcon"
                                                Margin="0,0,0,20"
                                                HorizontalOptions="FillAndExpand"
                                                IsVisible="false"
                                                Style="{StaticResource stackBMSDetailsInner}"
                                                VerticalOptions="StartAndExpand">
                                                <StackLayout Style="{StaticResource stackBMSDetailsPerStackOuter}" VerticalOptions="CenterAndExpand">
                                                    <Image
                                                        x:Name="imgHomeMinSOC"
