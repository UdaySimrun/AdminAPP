                                                    <ColumnDefinition x:Name="grdTemperatureUnitscln1" Width="160" />
                                                    <ColumnDefinition x:Name="grdTemperatureUnitscln3" Width="130" />
                                                </Grid.ColumnDefinitions>
                                                <Label
                                                    x:Name="lblTemperatureUnits"
                                                    Grid.Row="0"
                                                    Grid.Column="0"
                                                    Grid.ColumnSpan="2"
                                                    FontAttributes="Bold"
                                                    HorizontalOptions="StartAndExpand"
                                                    Style="{StaticResource NormalStyle}"
                                                    Text="Temperature Units :"
                                                    TextColor="Black"
                                                    VerticalOptions="CenterAndExpand" />
