                                                        HorizontalOptions="FillAndExpand"
                                                        Interval="5"
                                                        LabelCreated="rangesliderLowTemp_LabelCreated"
                                                        LabelsPlacement="OnTicks"
                                                        Maximum="50"
                                                        Minimum="35"
                                                        Orientation="Horizontal"
                                                        ShowLabels="True"
                                                        ShowTicks="True"
                                                        StepSize="5"
                                                        ValueChangeEnd="SfSliderValueChange_ValueChangeEnd"
                                                        VerticalOptions="FillAndExpand">
                                                        <range:SfSlider.LabelStyle>
                                                            <range:SliderLabelStyle
                                                                ActiveFontAutoScalingEnabled="False"
                                                                ActiveFontFamily="OpenSansRegular"
                                                                ActiveFontSize="{OnIdiom Phone=17,
                                                                                         Tablet=20}"
                                                                InactiveFontFamily="OpenSansRegular"
                                                                InactiveFontSize="{OnIdiom Phone=17,
                                                                                           Tablet=20}"
                                                                InactiveTextColor="Black" />
                                                        </range:SfSlider.LabelStyle>
