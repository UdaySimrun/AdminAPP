                                                                CircleColor="Black"
                                                                ClassId="CelsiusTempUnitRadio"
                                                                Clicked="RadioButtonChange_Clicked"
                                                                IsChecked="{Binding TemperatureUnit[0]}"
                                                                Scale="1.0"
                                                                Style="{StaticResource RadioNormalStyle}"
                                                                Text="Celsius"
                                                                TextColor="Black"
                                                                Color="#F99C00"
                                                                Value="Celsius" />
                                                            <input:RadioButton
                                                                x:Name="rdFahrenheit"
                                                                Margin="0,0,15,0"
                                                                BindingContext="{Binding Source={Local:RadioButtonViewModel}}"
                                                                CircleColor="Black"
                                                                ClassId="FahrenheitTempUnitRadio"
                                                                Clicked="RadioButtonChange_Clicked"
                                                                IsChecked="{Binding TemperatureUnit[1]}"
                                                                Scale="1.0"
                                                                Style="{StaticResource RadioNormalStyle}"
                                                                Text="Fahrenheit"
                                                                TextColor="Black"
                                                                Color="#F99C00"
                                                                Value="Fahrenheit" />
                                                        </FlexLayout>
                                                    </input:RadioButtonGroupView>
