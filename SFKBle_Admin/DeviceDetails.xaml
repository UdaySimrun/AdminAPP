                                                    CornerRadius="5"
                                                    HorizontalOptions="EndAndExpand"
                                                    Style="{StaticResource ToolTabButtonStyle}"
                                                    Text="Update"
                                                    TextColor="White"
                                                    TextTransform="None"
                                                    VerticalOptions="StartAndExpand" />
                                            </Grid>
                                            <!--  Low Temperature Heating (Charging)  -->
