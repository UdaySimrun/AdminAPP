                                                    Grid.ColumnSpan="2"
                                                    Padding="0,0,0,10"
                                                    HorizontalOptions="FillAndExpand"
                                                    IsVisible="True"
                                                    VerticalOptions="FillAndExpand">
                                                    <range:SfSlider
                                                        x:Name="rangesliderLowTemp"
