                                                    Background="#39B54A"
                                                    Clicked="btnMaxBatteryTemp_Clicked"
                                                    CornerRadius="5"
                                                    HorizontalOptions="EndAndExpand"
                                                    Style="{StaticResource ToolTabButtonStyle}"
                                                    Text="Update"
                                                    TextColor="White"
                                                    TextTransform="None"
                                                    VerticalOptions="CenterAndExpand" />
