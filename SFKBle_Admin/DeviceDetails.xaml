                                                    <RowDefinition Height="40" />
                                                    <RowDefinition Height="80" />
                                                    <RowDefinition Height="60" />
                                                </Grid.RowDefinitions>
                                                <Label
                                                    Grid.Row="0"
                                                    Grid.Column="0"
                                                    Grid.ColumnSpan="2"
                                                    FontAttributes="Bold"
                                                    HorizontalOptions="FillAndExpand"
                                                    Style="{StaticResource NormalStyle}"
                                                    Text="Maximum Operating Temperature :"
                                                    TextColor="Black"
                                                    VerticalOptions="StartAndExpand" />

                                                <Grid
                                                    x:Name="SliderGridrangesliderMaxBatteryTemp"
