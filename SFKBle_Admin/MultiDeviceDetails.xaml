            <StackLayout Padding="10" VerticalOptions="StartAndExpand">
                <Frame
                    x:Name="IsBusyIndicatorForReconnecing"
                    BackgroundColor="White"
                    BindingContext="{Binding Source={Local:BusyIndicatorReconnectionViewModel}}"
                    IsVisible="{Binding IsBusy}"
                    VerticalOptions="FillAndExpand">
                    <StackLayout VerticalOptions="FillAndExpand">
                        <Image
                            Margin="0,0,0,15"
                            HorizontalOptions="FillAndExpand"
                            IsVisible="true"
                            Source="attempttoreconect.png"
                            Style="{StaticResource SuccesPopupImageHeight}"
                            VerticalOptions="StartAndExpand" />
                        <Label
                            x:Name="IsBusyIndicatorForReconnecingLable"
                            BindingContext="{Binding Source={Local:BusyIndicatorReconnectionViewModel}}"
                            FontAttributes="Bold"
                            FontSize="20"
                            HorizontalOptions="CenterAndExpand"
                            HorizontalTextAlignment="Center"
                            Text="{Binding Message}"
                            TextColor="Black"
                            TextDecorations="None"
                            VerticalOptions="StartAndExpand" />
                        <Button
                            x:Name="btnCancelReconect"
                            BackgroundColor="#DC2624"
                            Clicked="btnCancelReconect_Clicked"
                            CornerRadius="5"
                            HorizontalOptions="CenterAndExpand"
                            Style="{StaticResource ToolTabButtonStyleForButton}"
                            Text="Cancel"
                            TextColor="White"
                            TextTransform="None"
                            VerticalOptions="CenterAndExpand" />
                    </StackLayout>
                </Frame>
            </StackLayout>
        </StackLayout>
        <Border
            x:Name="stkDisplayMessagePopUp"
            Margin="20,0,20,0"
            Padding="10,0,10,0"
            BackgroundColor="White"
            HorizontalOptions="CenterAndExpand"
            IsVisible="false"
            Stroke="White"
            VerticalOptions="CenterAndExpand"
            ZIndex="98">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
            </Border.StrokeShape>
            <StackLayout Padding="0,20,0,20" HorizontalOptions="FillAndExpand">
                <Image
                    x:Name="imgDisplay"
                    HorizontalOptions="FillAndExpand"
                    Source="settingsupdated.png"
                    Style="{StaticResource SuccesPopupImageHeight}"
                    VerticalOptions="StartAndExpand" />

                <ScrollView
                    x:Name="scrPopupText"
                    Margin="0,10,0,10"
                    HorizontalOptions="CenterAndExpand"
                    IsEnabled="False"
                    VerticalOptions="Fill"
                    VerticalScrollBarVisibility="Default">
                    <Label
                        x:Name="lblText"
                        FontAttributes="Bold"
                        HorizontalOptions="CenterAndExpand"
                        HorizontalTextAlignment="Center"
                        Style="{StaticResource PopupFontSize}"
                        Text=""
                        TextColor="#2D2D2D"
                        VerticalOptions="Center"
                        VerticalTextAlignment="Center" />
                </ScrollView>

                <StackLayout
                    x:Name="stackCancelAndYesButton"
                    HorizontalOptions="FillAndExpand"
                    IsVisible="False"
                    Orientation="Horizontal"
                    VerticalOptions="EndAndExpand">
                    <Border
                        x:Name="sbbtn1"
                        Margin="0,0,10,0"
                        Padding="20,0,20,0"
                        BackgroundColor="#39B54A"
                        HorizontalOptions="EndAndExpand"
                        VerticalOptions="CenterAndExpand">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="6" />
                        </Border.StrokeShape>
                        <StackLayout
                            Margin="8,8,8,8"
                            ClassId="Yes"
                            HorizontalOptions="FillAndExpand"
                            Orientation="Horizontal"
                            Spacing="5">
                            <Image
                                x:Name="imgyes"
                                HeightRequest="30"
                                Source="yes.png"
                                WidthRequest="30" />
                            <Label
                                x:Name="lblYes"
                                FontAttributes="Bold"
                                FontSize="18"
                                Text="Yes"
                                TextColor="#fff"
                                VerticalTextAlignment="Center" />
                        </StackLayout>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer NumberOfTapsRequired="1" Tapped="DisplayPopupYes_Clicked" />
                        </Border.GestureRecognizers>
                    </Border>
                    <Border
                        x:Name="sbbtn2"
                        Margin="10,0,0,0"
                        Padding="20,0,20,0"
                        BackgroundColor="#DC2624"
                        HorizontalOptions="StartAndExpand"
                        VerticalOptions="CenterAndExpand">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="6" />
                        </Border.StrokeShape>
                        <StackLayout
                            Margin="8,8,8,8"
                            ClassId="Cancel"
                            Orientation="Horizontal"
                            Spacing="5">
                            <Image
                                x:Name="imgCancel"
                                HeightRequest="30"
                                Source="cancelbutton.png" />
                            <Label
                                x:Name="lblCancel"
                                FontAttributes="Bold"
                                FontSize="18"
                                Text="Cancel"
                                TextColor="#fff"
                                VerticalTextAlignment="Center" />
                        </StackLayout>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer NumberOfTapsRequired="1" Tapped="DisplayPopup_Clicked" />
                        </Border.GestureRecognizers>
                    </Border>
                </StackLayout>
                <Border
                    x:Name="btnOK"
                    BackgroundColor="#39B54A"
                    HorizontalOptions="CenterAndExpand"
                    VerticalOptions="EndAndExpand">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="6" />
                    </Border.StrokeShape>
                    <StackLayout
                        Margin="10,5,10,5"
                        ClassId="Ok"
                        Orientation="Horizontal">
                        <Image
                            x:Name="imgOK"
                            HeightRequest="30"
                            HorizontalOptions="EndAndExpand"
                            Source="yes.png"
                            VerticalOptions="CenterAndExpand" />
                        <Label
                            x:Name="lblOK"
                            Padding="10,0,10,0"
                            FontAttributes="Bold"
                            FontSize="18"
                            HorizontalOptions="StartAndExpand"
                            Text="Ok"
                            TextColor="#fff"
                            VerticalOptions="CenterAndExpand"
                            VerticalTextAlignment="Center" />
                    </StackLayout>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer NumberOfTapsRequired="1" Tapped="DisplayPopup_Clicked" />
                    </Border.GestureRecognizers>
                </Border>
            </StackLayout>
        </Border>
    </Grid>
</ContentPage>
