<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SFKBle_Admin.MultiDeviceDetails"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:ListCollection="clr-namespace:System.Collections.Generic;assembly=netstandard"
    xmlns:Local="clr-namespace:SFKBle_Admin"
    xmlns:buttons="clr-namespace:Syncfusion.Maui.Buttons;assembly=Syncfusion.Maui.Buttons"
    xmlns:chart="clr-namespace:Syncfusion.Maui.Charts;assembly=Syncfusion.Maui.Charts"
    xmlns:combobox="clr-namespace:Syncfusion.Maui.Inputs;assembly=Syncfusion.Maui.Inputs"
    xmlns:core="clr-namespace:Syncfusion.Maui.Core;assembly=Syncfusion.Maui.Core"
    xmlns:gauge="clr-namespace:Syncfusion.Maui.Gauges;assembly=Syncfusion.Maui.Gauges"
    xmlns:input="clr-namespace:InputKit.Shared.Controls;assembly=InputKit.Maui"
    xmlns:range="clr-namespace:Syncfusion.Maui.Sliders;assembly=Syncfusion.Maui.Sliders"
    xmlns:segmentCollection="clr-namespace:System.Collections.Generic;assembly=netstandard"
    xmlns:syncfusion="clr-namespace:Syncfusion.Maui.ListView;assembly=Syncfusion.Maui.ListView"
    xmlns:tabView="clr-namespace:Syncfusion.Maui.TabView;assembly=Syncfusion.Maui.TabView"
    NavigationPage.HasNavigationBar="False">

    <ContentPage.BindingContext>
        <Local:BattetryData />
    </ContentPage.BindingContext>

    <Grid>
        <StackLayout BackgroundColor="#ffffff">
            <StackLayout
                BackgroundColor="White"
                HeightRequest="40"
                HorizontalOptions="FillAndExpand"
                Orientation="Vertical"
                VerticalOptions="Start">
                <StackLayout
                    Padding="5,0,5,0"
                    HorizontalOptions="FillAndExpand"
                    Orientation="Horizontal"
                    VerticalOptions="FillAndExpand">
                    <Image Source="sunfunkitslogowtb.png" WidthRequest="70" />
                    <Label
                        Padding="10,0,0,0"
                        FontAttributes="Bold"
                        FontSize="15"
                        HorizontalOptions="CenterAndExpand"
                        IsVisible="False"
                        Text="www.sunfunkits.com"
                        TextColor="Black" />
                    <Label
                        FontSize="15"
                        HorizontalOptions="FillAndExpand"
                        HorizontalTextAlignment="End"
                        Text="V9.38"
                        TextColor="Black"
                        VerticalOptions="CenterAndExpand" />
                </StackLayout>
                <BoxView
                    BackgroundColor="#f0c000"
                    HeightRequest="1"
                    HorizontalOptions="FillAndExpand"
                    VerticalOptions="Start" />
            </StackLayout>
            <tabView:SfTabView
                x:Name="MultiSKFTabView"
                EnableSwiping="False"
                IndicatorBackground="#F0C000"
                IndicatorPlacement="Top"
                IndicatorWidthMode="Stretch"
                IsEnabled="True"
                IsScrollButtonEnabled="True"
                SelectionChanged="MultiSKFTabView_SelectionChanged"
                TabBarHeight="70"
                TabBarPlacement="Bottom"
                TabWidthMode="Default"
                VerticalOptions="FillAndExpand">
                <tabView:SfTabItem
                    x:Name="Scan"
                    FontSize="16"
                    ImagePosition="Top"
                    ImageSource="scanicon.png"
                    Scale="1.5">
                    <tabView:SfTabItem.Content>
                        <StackLayout />
                    </tabView:SfTabItem.Content>
                </tabView:SfTabItem>
                <tabView:SfTabItem
                    x:Name="Main"
                    FontSize="16"
                    ImagePosition="Top"
                    ImageSource="homeicon.png"
                    ImageTextSpacing="5"
                    Scale="1.5"
                    TextColor="#F0C000">
                    <tabView:SfTabItem.Content>
                        <Grid>
                            <StackLayout Grid.Row="0">
                                <ScrollView
                                    x:Name="scrlHome"
                                    Scrolled="scrlHome_Scrolled"
                                    VerticalOptions="StartAndExpand"
                                    VerticalScrollBarVisibility="Never">
                                    <StackLayout
                                        x:Name="MainStack"
                                        Margin="0,15,0,0"
                                        HorizontalOptions="Fill"
                                        Orientation="Vertical"
                                        VerticalOptions="FillAndExpand">
                                        <StackLayout
                                            x:Name="stackMainBordersOne"
                                            HorizontalOptions="FillAndExpand"
                                            Orientation="Vertical"
                                            VerticalOptions="Fill">
                                            <Border
                                                x:Name="gridCircularOne"
                                                Margin="5,0,5,0"
                                                HorizontalOptions="Fill"
                                                Stroke="#F0C000"
                                                StrokeThickness="1"
                                                VerticalOptions="StartAndExpand">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="10" />
                                                </Border.StrokeShape>
                                                <StackLayout HorizontalOptions="FillAndExpand">
                                                    <StackLayout
                                                        BackgroundColor="#F0C000"
                                                        HeightRequest="40"
                                                        HorizontalOptions="FillAndExpand"
                                                        VerticalOptions="Fill">
                                                        <Grid ColumnSpacing="0">
                                                            <Label
                                                                x:Name="lblDeviceNameForDevice1"
                                                                Grid.Column="0"
                                                                Padding="15,0,0,0"
                                                                FontAttributes="Bold"
                                                                HeightRequest="40"
                                                                HorizontalOptions="StartAndExpand"
                                                                Style="{StaticResource BenchmarkDetailsStyle}"
                                                                Text="Device Name"
                                                                TextColor="Black"
                                                                VerticalTextAlignment="Center" />
                                                            <StackLayout
                                                                Grid.Column="1"
                                                                HeightRequest="40"
                                                                HorizontalOptions="EndAndExpand"
                                                                Orientation="Horizontal">
                                                                <Image
                                                                    x:Name="imgUpdateIconForDevice1"
                                                                    Margin="0,0,5,0"
                                                                    HeightRequest="25"
                                                                    IsAnimationPlaying="True"
                                                                    IsVisible="False"
                                                                    Source="updateicon.png"
                                                                    WidthRequest="30" />
                                                                <Image
                                                                    x:Name="imgFailIconForDevice1"
                                                                    Margin="0,0,5,0"
                                                                    HeightRequest="25"
                                                                    IsAnimationPlaying="True"
                                                                    IsVisible="False"
                                                                    Source="failedupdates.png"
                                                                    WidthRequest="30" />
                                                                <Image
                                                                    x:Name="imgBalancingEnableDisableForDevice1"
                                                                    Margin="0,0,5,0"
                                                                    HeightRequest="25"
                                                                    IsAnimationPlaying="True"
                                                                    IsVisible="False"
                                                                    Source="BalancingIcon.gif"
                                                                    WidthRequest="30" />
                                                                <Image
                                                                    x:Name="imgWarningEnableDisableForDevice1"
                                                                    Margin="0,0,5,0"
                                                                    HeightRequest="25"
                                                                    IsAnimationPlaying="True"
                                                                    Source="WarningIcon.gif"
                                                                    WidthRequest="30" />
                                                                <Image
                                                                    x:Name="imgChargingEnableDisableForDevice1"
                                                                    Margin="0,0,5,0"
                                                                    HeightRequest="25"
                                                                    Source="chargingenabled.png"
                                                                    WidthRequest="30" />
                                                                <Image
                                                                    x:Name="imgDischargingEnableDisableForDevice1"
                                                                    Margin="0,0,5,0"
                                                                    HeightRequest="25"
                                                                    Source="dischargingenabled.png"
                                                                    WidthRequest="30" />
                                                                <StackLayout
                                                                    x:Name="stackBatteryStatusForDevice1"
                                                                    Margin="0,0,0,0"
                                                                    BackgroundColor="#666666"
                                                                    HorizontalOptions="EndAndExpand"
                                                                    WidthRequest="45">
                                                                    <Image
                                                                        x:Name="imgBatteryStatusForDevice1"
                                                                        HeightRequest="25"
                                                                        HorizontalOptions="CenterAndExpand"
                                                                        IsAnimationPlaying="True"
                                                                        Source="standby.png"
                                                                        VerticalOptions="CenterAndExpand"
                                                                        WidthRequest="30" />
                                                                </StackLayout>
                                                            </StackLayout>
                                                        </Grid>
                                                    </StackLayout>

                                                    <StackLayout
                                                        x:Name="stackCircularOne"
                                                        Padding="5,10,10,10"
                                                        HorizontalOptions="Start"
                                                        Orientation="Horizontal"
                                                        VerticalOptions="Fill">
                                                        <Border
                                                            x:Name="gaugeOne"
                                                            Margin="0,0,0,0"
                                                            BackgroundColor="Transparent"
                                                            HorizontalOptions="Start"
                                                            StrokeThickness="0"
                                                            VerticalOptions="Fill">
                                                            <StackLayout Orientation="Horizontal">
                                                                <StackLayout
                                                                    x:Name="stackMainGaugeOne"
                                                                    HorizontalOptions="FillAndExpand"
                                                                    Orientation="Vertical"
                                                                    VerticalOptions="Fill">
                                                                    <StackLayout
                                                                        HorizontalOptions="{OnIdiom Phone='FillAndExpand',
                                                                                                    Tablet='CenterAndExpand'}"
                                                                        Orientation="Horizontal"
                                                                        Spacing="-20"
                                                                        VerticalOptions="FillAndExpand">
                                                                        <StackLayout
                                                                            x:Name="stackSOCAndRemainigAh1"
                                                                            Margin="7,-10,0,0"
                                                                            HorizontalOptions="Center"
                                                                            MinimumWidthRequest="90"
                                                                            VerticalOptions="StartAndExpand">
                                                                            <Label
                                                                                x:Name="gaugeSocForDevice1"
                                                                                FontAttributes="Bold"
                                                                                HorizontalOptions="FillAndExpand"
                                                                                HorizontalTextAlignment="Center"
                                                                                Style="{StaticResource DeviceSOCValue}"
                                                                                Text="0%"
                                                                                TextColor="Black"
                                                                                VerticalTextAlignment="Start" />
                                                                            <Label
                                                                                HorizontalOptions="Center"
                                                                                TextColor="Black"
                                                                                VerticalOptions="FillAndExpand">
                                                                                <Label.FormattedText>
                                                                                    <FormattedString>
                                                                                        <Span
                                                                                            x:Name="lblRemaining1"
                                                                                            FontAttributes="Bold"
                                                                                            Text="0.0" />
                                                                                        <Span FontAttributes="None" Text=" (AH)" />
                                                                                    </FormattedString>
                                                                                </Label.FormattedText>
                                                                            </Label>
                                                                        </StackLayout>
                                                                        <StackLayout
                                                                            x:Name="stackSinceFullCharge1"
                                                                            Margin="{OnIdiom Phone='10,0,0,0',
                                                                                             Tablet='25,0,0,0'}"
                                                                            HorizontalOptions="{OnIdiom Phone='EndAndExpand',
                                                                                                        Tablet='FillAndExpand'}"
                                                                            IsVisible="False"
                                                                            Orientation="Horizontal"
                                                                            VerticalOptions="StartAndExpand">
                                                                            <StackLayout Style="{StaticResource stackNFMainBMSDetails}">
                                                                                <Frame
                                                                                    x:Name="frmSinceFullCharge1"
                                                                                    Margin="0,0,7,0"
                                                                                    Padding="10,0,10,0"
                                                                                    BackgroundColor="#14B729"
                                                                                    CornerRadius="5"
                                                                                    HasShadow="False"
                                                                                    HorizontalOptions="FillAndExpand"
                                                                                    Style="{StaticResource frmHomeMainStatusMulti}"
                                                                                    VerticalOptions="StartAndExpand">
                                                                                    <Grid Style="{StaticResource grdMainPageFullChargeDesign}">
                                                                                        <Image
                                                                                            x:Name="imgSinceFullCharge1"
                                                                                            HorizontalOptions="CenterAndExpand"
                                                                                            Source="calender.png"
                                                                                            Style="{StaticResource imgMainPageFullChargeDesignMulti}"
                                                                                            VerticalOptions="CenterAndExpand" />
                                                                                        <StackLayout
                                                                                            HorizontalOptions="FillAndExpand"
                                                                                            Style="{StaticResource stackMainPageFullChargeDesign}"
                                                                                            VerticalOptions="FillAndExpand">
                                                                                            <Label
                                                                                                x:Name="lblSinceFullCharge1"
                                                                                                Margin="0,12,0,0"
                                                                                                FontAttributes="Bold"
                                                                                                HorizontalOptions="Center"
                                                                                                Style="{StaticResource lblSinceFullChargeDaysMulti}"
                                                                                                Text="0"
                                                                                                TextColor="Black"
                                                                                                VerticalOptions="CenterAndExpand" />
                                                                                        </StackLayout>
                                                                                    </Grid>
                                                                                </Frame>
                                                                            </StackLayout>
                                                                        </StackLayout>

                                                                    </StackLayout>

                                                                    <StackLayout
                                                                        x:Name="NF_stackMinMaxSocTemp1"
                                                                        HorizontalOptions="Center"
                                                                        IsVisible="false"
                                                                        Orientation="Horizontal"
                                                                        Style="{StaticResource NewFirmwareComponent}"
                                                                        VerticalOptions="Fill">
                                                                        <StackLayout Style="{StaticResource stackNFMainBMSDetails}">
                                                                            <Image
                                                                                x:Name="imgHomeMinSOC1"
                                                                                Source="soclowerlimit.png"
                                                                                Style="{StaticResource ValueIconStyle}"
                                                                                VerticalOptions="StartAndExpand" />
                                                                            <StackLayout Orientation="Vertical" Style="{StaticResource MainNameAndValueLabelStyle}">
                                                                                <Label
                                                                                    Style="{StaticResource NameLabelStyle}"
                                                                                    Text="SOC Lower Limit"
                                                                                    TextColor="#000000"
                                                                                    VerticalOptions="StartAndExpand" />
                                                                                <Label
                                                                                    x:Name="lblSOCLowerLimit1"
                                                                                    FontAttributes="Bold"
                                                                                    HorizontalTextAlignment="Start"
                                                                                    Style="{StaticResource ValueLabelStyle}"
                                                                                    Text="0.0"
                                                                                    TextColor="#000000"
                                                                                    VerticalTextAlignment="Start" />
                                                                            </StackLayout>
                                                                        </StackLayout>
                                                                        <StackLayout Style="{StaticResource stackNFMainBMSDetails}">
                                                                            <Image
                                                                                x:Name="imgHomeMaxSOC1"
                                                                                Source="socupperlimit.png"
                                                                                Style="{StaticResource ValueIconStyle}"
                                                                                VerticalOptions="StartAndExpand" />
                                                                            <StackLayout Orientation="Vertical" Style="{StaticResource MainNameAndValueLabelStyle}">
                                                                                <Label
                                                                                    HorizontalOptions="StartAndExpand"
                                                                                    Style="{StaticResource NameLabelStyle}"
                                                                                    Text="Volts"
                                                                                    TextColor="#000000"
                                                                                    VerticalOptions="StartAndExpand" />
                                                                                <Label
                                                                                    x:Name="lblSOCUpperLimit1"
                                                                                    FontAttributes="Bold"
                                                                                    HorizontalTextAlignment="Start"
                                                                                    Style="{StaticResource ValueLabelStyle}"
                                                                                    Text="0"
                                                                                    TextColor="#000000"
                                                                                    VerticalTextAlignment="Start" />
                                                                            </StackLayout>
                                                                        </StackLayout>
                                                                        <StackLayout Style="{StaticResource stackNFMainBMSDetails}">
                                                                            <Image
                                                                                x:Name="imgHeatingMode1"
                                                                                Source="lowtempchargingheatingmode.png"
                                                                                Style="{StaticResource ValueIconStyle}"
                                                                                VerticalOptions="StartAndExpand" />
                                                                            <StackLayout Orientation="Vertical" Style="{StaticResource MainNameAndValueLabelStyle}">
                                                                                <Label
                                                                                    Style="{StaticResource NameLabelStyle}"
                                                                                    Text="HeatingMode"
                                                                                    TextColor="#000000"
                                                                                    VerticalOptions="StartAndExpand" />
                                                                                <Label
                                                                                    x:Name="lblHeatingMode1"
                                                                                    FontAttributes="Bold"
                                                                                    HorizontalTextAlignment="Start"
                                                                                    Style="{StaticResource ValueLabelStyle}"
                                                                                    Text="0"
                                                                                    TextColor="#000000"
                                                                                    VerticalTextAlignment="Start" />
                                                                            </StackLayout>
                                                                        </StackLayout>
                                                                    </StackLayout>
                                                                </StackLayout>
                                                                <BoxView
                                                                    Margin="10,0,5,0"
                                                                    Background="Transparent"
                                                                    WidthRequest="1" />
                                                            </StackLayout>
                                                        </Border>

                                                        <StackLayout
                                                            x:Name="stackMainBoxOne"
                                                            HorizontalOptions="Start"
                                                            Orientation="Vertical"
                                                            Style="{StaticResource MainBoxStackStyle}"
                                                            VerticalOptions="Fill">
                                                            <StackLayout
                                                                HorizontalOptions="Start"
                                                                Orientation="Horizontal"
                                                                VerticalOptions="Fill">
                                                                <StackLayout Style="{StaticResource stackMainBMSDetails}">
                                                                    <Image
                                                                        Source="voltsicon.png"
                                                                        Style="{StaticResource ValueIconStyle}"
                                                                        VerticalOptions="StartAndExpand" />
                                                                    <StackLayout Orientation="Vertical" Style="{StaticResource MainNameAndValueLabelStyle}">
                                                                        <Label
                                                                            HorizontalOptions="StartAndExpand"
                                                                            Style="{StaticResource NameLabelStyle}"
                                                                            Text="Volts"
                                                                            TextColor="#000000"
                                                                            VerticalOptions="StartAndExpand" />
                                                                        <Label
                                                                            x:Name="lblVolts1"
                                                                            FontAttributes="Bold"
                                                                            HorizontalTextAlignment="Start"
                                                                            Style="{StaticResource ValueLabelStyle}"
                                                                            Text="0"
                                                                            TextColor="#000000"
                                                                            VerticalTextAlignment="Start" />
                                                                    </StackLayout>
                                                                </StackLayout>
                                                                <StackLayout Style="{StaticResource stackMainBMSDetails}">
                                                                    <Image
                                                                        Source="ampsicon.png"
                                                                        Style="{StaticResource ValueIconStyle}"
                                                                        VerticalOptions="StartAndExpand" />
                                                                    <StackLayout Orientation="Vertical" Style="{StaticResource MainNameAndValueLabelStyle}">
                                                                        <Label
                                                                            Style="{StaticResource NameLabelStyle}"
                                                                            Text="Amps"
                                                                            TextColor="#000000"
                                                                            VerticalOptions="StartAndExpand" />
                                                                        <Label
                                                                            x:Name="lblAmps1"
                                                                            FontAttributes="Bold"
                                                                            HorizontalTextAlignment="Start"
                                                                            Style="{StaticResource ValueLabelStyle}"
                                                                            Text="0.00"
                                                                            TextColor="#000000"
                                                                            VerticalTextAlignment="Start" />
                                                                    </StackLayout>
                                                                </StackLayout>
                                                                <StackLayout Style="{StaticResource stackMainBMSDetails}">
                                                                    <Image
                                                                        Source="wattsicon.png"
                                                                        Style="{StaticResource ValueIconStyle}"
                                                                        VerticalOptions="StartAndExpand" />
                                                                    <StackLayout Orientation="Vertical" Style="{StaticResource MainNameAndValueLabelStyle}">
                                                                        <Label
                                                                            HorizontalOptions="StartAndExpand"
                                                                            IsEnabled="False"
                                                                            Style="{StaticResource NameLabelStyle}"
                                                                            Text="Watts"
                                                                            TextColor="#000000"
                                                                            VerticalOptions="StartAndExpand" />
                                                                        <Label
                                                                            x:Name="lblWatts1"
                                                                            FontAttributes="Bold"
                                                                            HorizontalTextAlignment="Start"
                                                                            Style="{StaticResource ValueLabelStyle}"
                                                                            Text="0.00"
                                                                            TextColor="#000000"
                                                                            VerticalTextAlignment="Start" />
                                                                    </StackLayout>
                                                                </StackLayout>
                                                                <StackLayout Style="{StaticResource stackMainBMSDetails}">
                                                                    <Image
                                                                        Source="bmstemp.png"
                                                                        Style="{StaticResource ValueIconStyle}"
                                                                        VerticalOptions="StartAndExpand" />
                                                                    <StackLayout Orientation="Vertical" Style="{StaticResource MainNameAndValueLabelStyle}">
                                                                        <Label
                                                                            HorizontalOptions="StartAndExpand"
                                                                            Style="{StaticResource NameLabelStyle}"
                                                                            Text="Bms T."
                                                                            TextColor="#000000"
                                                                            VerticalOptions="StartAndExpand" />
                                                                        <Label
                                                                            x:Name="lblBMSTemp1"
                                                                            FontAttributes="Bold"
                                                                            HorizontalTextAlignment="Start"
                                                                            Style="{StaticResource ValueLabelStyle}"
                                                                            Text="0"
                                                                            TextColor="#000000" />
                                                                    </StackLayout>
                                                                </StackLayout>
                                                                <StackLayout x:Name="stackMainBMSDetailsCaseDevice1" Style="{StaticResource stackMainBMSDetailsCase}">
                                                                    <Image
                                                                        Source="casetemp1.png"
                                                                        Style="{StaticResource ValueIconStyle}"
                                                                        VerticalOptions="StartAndExpand" />
                                                                    <StackLayout Orientation="Vertical" Style="{StaticResource MainNameAndValueLabelStyle}">
                                                                        <Label
                                                                            HorizontalOptions="StartAndExpand"
                                                                            Style="{StaticResource NameLabelStyle}"
                                                                            Text="Case T."
                                                                            TextColor="#000000"
                                                                            VerticalOptions="StartAndExpand" />
                                                                        <Label
                                                                            x:Name="lblCaseTemp1"
                                                                            FontAttributes="Bold"
                                                                            HorizontalTextAlignment="Start"
                                                                            Style="{StaticResource ValueLabelStyle}"
                                                                            Text="0"
                                                                            TextColor="#000000" />
                                                                        <Label
                                                                            x:Name="lblCaseTemp21"
                                                                            FontAttributes="Bold"
                                                                            HorizontalTextAlignment="Start"
                                                                            IsEnabled="False"
                                                                            IsVisible="false"
                                                                            Style="{StaticResource ValueLabelStyle}"
                                                                            Text="0"
                                                                            TextColor="#000000" />
                                                                    </StackLayout>
                                                                    <StackLayout.GestureRecognizers>
                                                                        <TapGestureRecognizer
                                                                            x:Name="stackCaseTempDevice1"
                                                                            NumberOfTapsRequired="1"
                                                                            Tapped="stackCaseTempDevice1_Tapped" />
                                                                    </StackLayout.GestureRecognizers>
                                                                </StackLayout>
                                                            </StackLayout>

                                                            <StackLayout
                                                                x:Name="stackWarningOne"
                                                                HorizontalOptions="StartAndExpand"
                                                                Orientation="Horizontal"
                                                                VerticalOptions="CenterAndExpand">
                                                                <StackLayout x:Name="stackMainBMSDetailsCaseMblDevice1" Style="{StaticResource stackMainBMSDetailsCaseMbl}">
                                                                    <Image
                                                                        Source="casetemp1.png"
                                                                        Style="{StaticResource ValueIconStyle}"
                                                                        VerticalOptions="StartAndExpand" />
                                                                    <StackLayout Orientation="Vertical" Style="{StaticResource MainNameAndValueLabelStyle}">
                                                                        <Label
                                                                            HorizontalOptions="StartAndExpand"
                                                                            Style="{StaticResource NameLabelStyle}"
                                                                            Text="Case T."
                                                                            TextColor="#000000"
                                                                            VerticalOptions="StartAndExpand" />
                                                                        <Label
                                                                            x:Name="lblCaseTemp1Mbl"
                                                                            FontAttributes="Bold"
                                                                            HorizontalTextAlignment="Start"
                                                                            Style="{StaticResource ValueLabelStyle}"
                                                                            Text="0"
                                                                            TextColor="#000000" />
                                                                        <Label
                                                                            x:Name="lblCaseTemp21Mbl"
                                                                            FontAttributes="Bold"
                                                                            HorizontalTextAlignment="Start"
                                                                            IsEnabled="False"
                                                                            IsVisible="false"
                                                                            Style="{StaticResource ValueLabelStyle}"
                                                                            Text="0"
                                                                            TextColor="#000000" />
                                                                    </StackLayout>
                                                                    <StackLayout.GestureRecognizers>
                                                                        <TapGestureRecognizer
                                                                            x:Name="stackCaseTempDevice1Mbl"
                                                                            NumberOfTapsRequired="1"
                                                                            Tapped="stackCaseTempDevice1_Tapped" />
                                                                    </StackLayout.GestureRecognizers>
                                                                </StackLayout>
                                                                <ScrollView
                                                                    HorizontalOptions="StartAndExpand"
                                                                    HorizontalScrollBarVisibility="Never"
                                                                    Orientation="Horizontal"
                                                                    VerticalOptions="StartAndExpand"
                                                                    VerticalScrollBarVisibility="Never">
                                                                    <StackLayout
                                                                        x:Name="stackWarningInnerDevice1"
                                                                        Margin="5,0,0,0"
                                                                        HorizontalOptions="StartAndExpand"
                                                                        Orientation="Horizontal">
                                                                        <Border
                                                                            x:Name="FirstWarningForDevice1"
                                                                            Grid.Row="0"
                                                                            Grid.Column="0"
                                                                            Padding="2,0,2,0"
                                                                            IsVisible="false"
                                                                            Stroke="#707070"
                                                                            StrokeThickness="0">
                                                                            <StackLayout Orientation="Vertical">
                                                                                <Image
                                                                                    x:Name="imgFirstWarningForDevice1"
                                                                                    Source="cellovervolt.png"
                                                                                    Style="{StaticResource MultiMainWarningImage}" />
                                                                                <Label
                                                                                    x:Name="lblFirstWarningForDevice1"
                                                                                    FontAttributes="Bold"
                                                                                    HorizontalTextAlignment="Center"
                                                                                    Style="{StaticResource WarningLabelStyle}"
                                                                                    TextColor="Black"
                                                                                    VerticalTextAlignment="Center" />
                                                                            </StackLayout>
                                                                        </Border>
                                                                        <Border
                                                                            x:Name="SecoundWarningForDevice1"
                                                                            Grid.Row="0"
                                                                            Grid.Column="1"
                                                                            Padding="2,0,2,0"
                                                                            IsVisible="false"
                                                                            Stroke="#707070"
                                                                            StrokeThickness="0">
                                                                            <StackLayout Orientation="Vertical">
                                                                                <Image
                                                                                    x:Name="imgSecoundWarningForDevice1"
                                                                                    Source="cellovervolt.png"
                                                                                    Style="{StaticResource MultiMainWarningImage}" />
                                                                                <Label
                                                                                    x:Name="lblSecoundWarningForDevice1"
                                                                                    FontAttributes="Bold"
                                                                                    HorizontalTextAlignment="Center"
                                                                                    Style="{StaticResource WarningLabelStyle}"
                                                                                    TextColor="Black"
                                                                                    VerticalTextAlignment="Center" />
                                                                            </StackLayout>
                                                                        </Border>
                                                                        <Border
                                                                            x:Name="ThirdWarningForDevice1"
                                                                            Grid.Row="0"
                                                                            Grid.Column="2"
                                                                            Padding="2,0,2,0"
                                                                            IsVisible="false"
                                                                            Stroke="#707070"
                                                                            StrokeThickness="0">
                                                                            <StackLayout Orientation="Vertical">
                                                                                <Image
                                                                                    x:Name="imgThirdWarningForDevice1"
                                                                                    Source="cellovervolt.png"
                                                                                    Style="{StaticResource MultiMainWarningImage}" />
                                                                                <Label
                                                                                    x:Name="lblThirdWarningForDevice1"
                                                                                    FontAttributes="Bold"
                                                                                    HorizontalTextAlignment="Center"
                                                                                    Style="{StaticResource WarningLabelStyle}"
                                                                                    TextColor="Black"
                                                                                    VerticalTextAlignment="Center" />
                                                                            </StackLayout>
                                                                        </Border>
                                                                        <Border
                                                                            x:Name="FourthWarningForDevice1"
                                                                            Grid.Row="0"
                                                                            Grid.Column="3"
                                                                            Padding="2,0,2,0"
                                                                            IsVisible="false"
                                                                            Stroke="#707070"
                                                                            StrokeThickness="0">
                                                                            <StackLayout Orientation="Vertical">
                                                                                <Image
                                                                                    x:Name="imgFourthWarningForDevice1"
                                                                                    Source="cellovervolt.png"
                                                                                    Style="{StaticResource MultiMainWarningImage}" />
                                                                                <Label
                                                                                    x:Name="lblFourthWarningForDevice1"
                                                                                    FontAttributes="Bold"
                                                                                    HorizontalTextAlignment="Center"
                                                                                    Style="{StaticResource WarningLabelStyle}"
                                                                                    TextColor="Black"
                                                                                    VerticalTextAlignment="Center" />
